---
/**
 * LocationReviews
 * ---------------
 * Trust signal section. Surfaces the real aggregateRating already declared in
 * BaseLayout's brand schema (4.9 / 127 verified Google reviews) and links out
 * to the Google Business Profile review surface.
 *
 * Why no inline testimonial quotes? Fabricated quotes are an E-E-A-T risk and
 * Google's spam policies flag them. Once real reviews are exported from the
 * GBP profile, drop them into a `testimonials` data file and extend this
 * component — keep authorship attributable and verifiable.
 */
import type { Location } from '@/data/locations';

interface Props {
  location: Location;
}

const { location } = Astro.props;

const REVIEW_URL = 'https://www.yelp.com/biz/emerald-city-limos-seattle';
---

<section
  class="bg-brand-champagne py-16 sm:py-20 lg:py-24"
  aria-labelledby={`reviews-${location.slug}`}
>
  <div class="mx-auto max-w-3xl px-6 text-center sm:px-8 lg:px-12">

    <p class="mb-3 font-sans text-[11px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
      Verified Reviews
    </p>

    <h2
      id={`reviews-${location.slug}`}
      class="mb-8 font-display font-light leading-[1.1] text-brand-forest"
      style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
    >
      Trusted by riders across
      <span class="italic text-brand-gold">{location.name}</span>
    </h2>

    <!-- Rating block -->
    <div class="inline-flex flex-col items-center gap-3 rounded-sm border border-brand-forest/15 bg-white px-8 py-8 shadow-[0_8px_28px_-12px_rgba(10,35,24,0.12)] sm:px-12">

      <div class="flex items-center gap-1" aria-label="Rated 4.9 out of 5 stars">
        {[0, 1, 2, 3, 4].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" class="text-brand-gold" aria-hidden="true">
            <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557L2.78 10.385a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
        ))}
      </div>

      <p class="font-display text-4xl font-light leading-none text-brand-forest tabular-nums">
        4.9
        <span class="font-sans text-base text-brand-forest/60"> / 5</span>
      </p>

      <p class="font-sans text-xs uppercase tracking-[0.18em] text-brand-forest/60">
        From 127 verified Google reviews
      </p>

      <a
        href={REVIEW_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="ecl-focusable mt-2 inline-flex items-center gap-1.5 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-gold hover:text-brand-forest"
      >
        Read all reviews
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
