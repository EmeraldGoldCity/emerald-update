---
/**
 * LocationCTA
 * -----------
 * Final conversion section — the "page-ending" CTA the LocationLayout header
 * comment refers to. Brand-forest gradient background with gold accent rule
 * to match the hero's visual bookend.
 */
import type { Location } from '@/data/locations';

interface Props {
  location: Location;
}

const { location } = Astro.props;

const PHONE = '(206) 595-9675';
const TEL_HREF = 'tel:+12065959675';
---

<section
  class="relative overflow-hidden bg-brand-forest py-20 text-white sm:py-24"
  aria-labelledby={`cta-${location.slug}`}
>
  <!-- Top gold rule -->
  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(163,126,44,0.5), transparent);"
    aria-hidden="true"
  ></div>

  <!-- Subtle radial gradient for depth -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(163,126,44,0.08) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-3xl px-6 text-center sm:px-8 lg:px-12">

    <p class="mb-3 font-sans text-[11px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
      Reserve your chauffeur
    </p>

    <h2
      id={`cta-${location.slug}`}
      class="mb-6 font-display font-light leading-[1.1] text-white"
      style="font-size: clamp(2rem, 4vw, 3rem);"
    >
      Book your
      <span class="italic text-brand-gold-soft">{location.name}</span>
      ride
    </h2>

    <p class="mx-auto mb-10 max-w-xl font-sans text-base leading-relaxed text-white/75 sm:text-lg">
      Available 24/7. Live flight tracking on every airport pickup. No surge pricing, no hidden tolls.
    </p>

    <div
      class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4"
      role="group"
      aria-label={`Booking options for ${location.name}`}
    >
      <a
        href="https://customer.moovs.app/a1-charters-1/new/info"
        target="_blank"
        rel="noopener noreferrer"
        data-cta="location_cta_book_now"
        aria-label={`Book your ${location.name} chauffeur now`}
        class="ecl-focusable inline-flex min-h-[52px] w-full items-center justify-center gap-2 rounded-none border border-brand-gold-soft bg-brand-gold-soft px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-forest sm:w-auto"
      >
        Book Now
        <span aria-hidden="true">→</span>
      </a>

      <a
        href={TEL_HREF}
        data-cta="location_cta_call"
        aria-label={`Call ${PHONE}`}
        class="ecl-focusable inline-flex min-h-[52px] w-full items-center justify-center gap-2 rounded-none border border-white/40 bg-transparent px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-white hover:border-white/70 sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        <span class="tabular-nums">{PHONE}</span>
      </a>
    </div>
  </div>

  <!-- Bottom gold rule -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(163,126,44,0.3), transparent);"
    aria-hidden="true"
  ></div>
</section>

<script is:inline>
  document.querySelectorAll('a[data-cta^="location_cta"]').forEach((el) => {
    el.addEventListener('click', () => {
      const label = el.getAttribute('data-cta');
      if (window.gtag) window.gtag('event', 'click', { event_category: 'location_cta', event_label: label });
    });
  });
</script>
