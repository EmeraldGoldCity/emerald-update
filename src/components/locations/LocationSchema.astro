---
/**
 * LocationSchema
 * --------------
 * Per-page JSON-LD for /locations/[slug]. Emits four blocks:
 *   1. LocalBusiness — city-scoped LimousineService with GeoCoordinates,
 *      areaServed, and aggregateRating inherited from BaseLayout brand schema.
 *   2. Service[] — one node per locationServices entry, scoped to the city.
 *   3. FAQPage — built from location.faqs (if present).
 *   4. BreadcrumbList — Home › Locations › City.
 *
 * Google parses JSON-LD from anywhere in the document, so this component is
 * dropped at the bottom of the page template. Keep all four nodes in a single
 * @graph payload to avoid duplicate @id collisions across crawlers.
 *
 * Sources:
 *   - Schema.org LocalBusiness: https://schema.org/LocalBusiness
 *   - Google FAQPage guidelines: https://developers.google.com/search/docs/appearance/structured-data/faqpage
 *   - Google Breadcrumb guidelines: https://developers.google.com/search/docs/appearance/structured-data/breadcrumb
 */
import type { Location } from '@/data/locations';
import { locationServices } from '@/data/locationServices';

interface Props {
  location: Location;
}

const { location } = Astro.props;

const SITE_URL = 'https://emeraldcitylimos.com';
const PAGE_URL = `${SITE_URL}/locations/${location.slug}`;
const PHONE = '+1-206-595-9675';

const businessNode = {
  '@type': 'LimousineService',
  '@id': `${PAGE_URL}#business`,
  name: `Emerald City Limos — ${location.name}`,
  url: PAGE_URL,
  telephone: PHONE,
  email: 'client@emeraldcitylimos.com',
  image: new URL(location.heroImage.src, SITE_URL).href,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: location.name,
    addressRegion: 'WA',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: location.coordinates.lat,
    longitude: location.coordinates.lng,
  },
  areaServed: {
    '@type': 'City',
    name: location.name,
    containedInPlace: { '@type': 'AdministrativeArea', name: location.county },
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '127',
    bestRating: '5',
    worstRating: '1',
  },
};

const serviceNodes = locationServices.map((svc) => ({
  '@type': 'Service',
  '@id': `${PAGE_URL}#service-${svc.id}`,
  name: `${svc.title} in ${location.name}`,
  description: svc.description,
  provider: { '@id': `${PAGE_URL}#business` },
  areaServed: { '@type': 'City', name: location.name },
  serviceType: svc.title,
  url: `${SITE_URL}${svc.href}`,
}));

const faqNode =
  location.faqs && location.faqs.length > 0
    ? {
        '@type': 'FAQPage',
        '@id': `${PAGE_URL}#faq`,
        mainEntity: location.faqs.map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: { '@type': 'Answer', text: faq.answer },
        })),
      }
    : null;

const breadcrumbNode = {
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${SITE_URL}/locations` },
    { '@type': 'ListItem', position: 3, name: location.name, item: PAGE_URL },
  ],
};

const graph = [
  businessNode,
  ...serviceNodes,
  breadcrumbNode,
  ...(faqNode ? [faqNode] : []),
];

const payload = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(payload)} />
