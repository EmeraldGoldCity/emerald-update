---
/**
 * LocationHero
 * ------------
 * Full-bleed hero for /locations/[slug]. Mirrors the design language of
 * src/components/hero/Hero.astro at a smaller scale (sub-page, not landing).
 *
 * Heading pattern is fixed by spec:
 *   "Luxury Chauffeur Service in {Location}"
 *
 * The supporting paragraph and image come from src/data/locations.ts so each
 * city reads uniquely (avoids thin-content / duplicate-content penalties).
 *
 * No React island — Astro static markup with inline gtag click capture.
 */
import type { Location } from '@/data/locations';

interface Props {
  location: Location;
}

const { location } = Astro.props;

const PHONE = '(206) 595-9675';
const TEL_HREF = 'tel:+12065959675';
---

<section
  class="ecl-noise relative w-full overflow-hidden"
  aria-labelledby={`hero-${location.slug}`}
>
  <!-- Background image (LCP candidate on this route) -->
  <img
    src={location.heroImage}
    alt={location.heroImageAlt}
    width="1920"
    height="1080"
    fetchpriority="high"
    loading="eager"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover object-center"
  />

  <!-- Three-layer overlay for legibility -->
  <div class="absolute inset-0 bg-brand-forest/55" aria-hidden="true"></div>
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(10,35,24,0.20) 0%, rgba(10,35,24,0.40) 40%, rgba(10,35,24,0.78) 75%, rgba(10,35,24,0.94) 100%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 80% 60% at 50% 40%, transparent 0%, rgba(10,35,24,0.30) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Top decorative gold rule -->
  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(163,126,44,0.5), transparent);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 flex min-h-[68svh] flex-col justify-end px-6 pb-14 pt-24 sm:px-8 sm:pb-20 sm:pt-32 md:px-12">
    <div class="mx-auto w-full max-w-4xl text-center">

      <!-- Eyebrow: County -->
      <div class="mb-5 flex items-center justify-center gap-3 sm:mb-7">
        <span
          class="hidden h-px w-12 sm:block"
          style="background: linear-gradient(to right, transparent, rgba(163,126,44,0.6));"
          aria-hidden="true"
        ></span>
        <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft sm:text-[11px]">
          {location.county}
        </p>
        <span
          class="hidden h-px w-12 sm:block"
          style="background: linear-gradient(to left, transparent, rgba(163,126,44,0.6));"
          aria-hidden="true"
        ></span>
      </div>

      <!-- H1 -->
      <h1
        id={`hero-${location.slug}`}
        class="mb-4 font-display font-extralight leading-[1.05] tracking-[-0.02em] text-white sm:mb-6"
        style="font-size: clamp(2rem, 5.2vw + 0.35rem, 4rem);"
      >
        <span class="block">Luxury Chauffeur Service in</span>
        <span class="block italic text-brand-gold-soft">{location.name}</span>
      </h1>

      <!-- Supporting paragraph -->
      <p
        class="mx-auto mb-8 max-w-xl font-sans font-light leading-relaxed tracking-[0.01em] text-white/80 sm:mb-10"
        style="font-size: clamp(0.95rem, 1.6vw, 1.075rem);"
      >
        {location.heroSupporting}
      </p>

      <!-- CTAs -->
      <div
        class="mb-12 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4"
        role="group"
        aria-label="Booking options"
      >
        <a
          href="/book-now"
          data-cta="location_hero_book_now"
          aria-label={`Book Now — ${location.name} chauffeur service`}
          class="ecl-focusable inline-flex min-h-[52px] w-full items-center justify-center gap-2 rounded-none border border-brand-gold-soft bg-brand-gold-soft px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-forest sm:w-auto"
        >
          Book Now
          <span aria-hidden="true">→</span>
        </a>

        <a
          href={TEL_HREF}
          data-cta="location_hero_call"
          aria-label={`Get a quote — call ${PHONE}`}
          class="ecl-focusable inline-flex min-h-[52px] w-full items-center justify-center gap-2 rounded-none border border-white/40 bg-transparent px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-white hover:border-white/70 sm:w-auto"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <span class="tabular-nums">Get a Quote</span>
        </a>
      </div>

      <!-- Trust strip -->
      <div>
        <div class="mx-auto mb-6 h-6 w-px bg-brand-gold-soft opacity-30" aria-hidden="true"></div>
        <ul
          class="m-0 flex list-none flex-wrap items-center justify-center gap-x-6 gap-y-3 p-0 sm:gap-x-8"
          role="list"
          aria-label="Service credentials"
        >
          <li class="flex items-center gap-2 font-sans text-[10px] font-medium uppercase tracking-[0.14em] text-white/65 sm:text-[11px]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13" class="flex-shrink-0 text-brand-gold" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
            Licensed &amp; Insured
          </li>
          <li class="flex items-center gap-2 font-sans text-[10px] font-medium uppercase tracking-[0.14em] text-white/65 sm:text-[11px]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13" class="flex-shrink-0 text-brand-gold" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            24/7 Availability
          </li>
          <li class="flex items-center gap-2 font-sans text-[10px] font-medium uppercase tracking-[0.14em] text-white/65 sm:text-[11px]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="13" height="13" class="flex-shrink-0 text-brand-gold" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
            Professional Chauffeurs
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom decorative gold rule -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(163,126,44,0.3), transparent);"
    aria-hidden="true"
  ></div>
</section>

<script is:inline>
  document.querySelectorAll('a[data-cta^="location_hero"]').forEach((el) => {
    el.addEventListener('click', () => {
      const label = el.getAttribute('data-cta');
      if (window.gtag) window.gtag('event', 'click', { event_category: 'location_hero_cta', event_label: label });
    });
  });
</script>
