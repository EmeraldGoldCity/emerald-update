---
/**
 * ContactHours
 * ------------
 * Dark hours + coverage band. Communicates that dispatch is always
 * staffed and lists the service area at a glance.
 */
const hours = [
  { label: 'Dispatch line', value: 'Open 24 / 7 · 365 days' },
  { label: 'Email replies', value: 'Within one business hour' },
  { label: 'Same-day requests', value: 'Subject to fleet availability' },
];

const coverage = [
  'King County',
  'Snohomish County',
  'Pierce County',
  'SEA · BFI · PAE',
];
---

<section
  class="relative overflow-hidden bg-brand-forest py-16 text-brand-champagne sm:py-20 lg:py-24"
  aria-labelledby="contact-hours-heading"
>
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(163,126,44,0.16) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div class="mb-10 text-center sm:mb-12">
      <div class="mb-3 flex items-center justify-center gap-3">
        <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
        <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
          Hours & Coverage
        </p>
        <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
      </div>
      <h2
        id="contact-hours-heading"
        class="mx-auto max-w-2xl font-display font-light leading-[1.1] text-white"
        style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
      >
        Available
        <em class="italic text-brand-gold-soft">every hour of every day.</em>
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2 md:gap-5">
      <!-- Hours card -->
      <article class="border border-white/8 bg-white/[0.04] p-6 sm:p-7">
        <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
          When we answer
        </p>
        <dl class="m-0 mt-4 divide-y divide-white/10 p-0">
          {hours.map((row) => (
            <div class="flex items-start justify-between gap-6 py-3.5">
              <dt class="font-sans text-[0.78rem] font-medium text-white/65">
                {row.label}
              </dt>
              <dd class="text-right font-sans text-[0.92rem] font-medium leading-snug text-white">
                {row.value}
              </dd>
            </div>
          ))}
        </dl>
      </article>

      <!-- Coverage card -->
      <article class="border border-white/8 bg-white/[0.04] p-6 sm:p-7">
        <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
          Where we serve
        </p>
        <p class="mt-2 font-display text-lg font-medium leading-snug text-white">
          Greater Seattle &amp; the Puget Sound metro
        </p>
        <ul role="list" class="m-0 mt-4 flex list-none flex-wrap gap-2 p-0">
          {coverage.map((area) => (
            <li class="inline-flex items-center border border-brand-gold-soft/35 bg-brand-gold-soft/5 px-3 py-1.5 font-sans text-[0.75rem] font-medium tracking-[0.04em] text-brand-gold-soft">
              {area}
            </li>
          ))}
        </ul>
        <p class="mt-5 font-sans text-[0.82rem] font-light leading-relaxed text-white/65">
          Outside the metro? We routinely run long-haul charters into the
          Olympic Peninsula, Mt. Rainier, and Eastern Washington —
          <a
            href="/book-now?intent=quote"
            class="font-semibold text-brand-gold-soft underline-offset-2 outline-none hover:text-white hover:underline focus-visible:underline focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
          >ask for a quote</a>.
        </p>
      </article>
    </div>
  </div>
</section>
