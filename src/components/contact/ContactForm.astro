---
/**
 * ContactForm
 * -----------
 * Accessible mailto: contact form. Native HTML form with progressive-
 * enhancement script: on submit, the script intercepts, builds a
 * mailto: URL with subject + URL-encoded body, and opens the user's
 * mail client with everything pre-filled. If JS is disabled, the form
 * still falls back to a plain mailto: action (opens an empty draft).
 *
 * Why mailto: instead of a backend?
 *   - Zero backend dependency, zero spam risk, zero cost.
 *   - Easy to upgrade later: swap the action attribute to a Web3Forms
 *     / Formspree / serverless endpoint and remove the JS handler.
 */
const EMAIL = 'client@emeraldcitylimos.com';

const inquiryTypes = [
  'General question',
  'Quote request',
  'Airport transfer',
  'Wedding inquiry',
  'Corporate account',
  'Other',
];
---

<section
  class="bg-brand-champagne py-16 sm:py-20 lg:py-24"
  aria-labelledby="contact-form-heading"
>
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">

      <!-- ── Form column ─────────────────────────────────── -->
      <div>
        <div class="mb-4 flex items-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            Send a Message
          </p>
        </div>
        <h2
          id="contact-form-heading"
          class="mb-6 font-display font-light leading-[1.08] text-brand-forest"
          style="font-size: clamp(1.85rem, 3.4vw, 2.5rem); letter-spacing: -0.01em;"
        >
          Tell us about
          <em class="italic text-brand-gold">your ride.</em>
        </h2>

        <p class="mb-8 max-w-lg font-sans text-[0.98rem] font-light leading-[1.75] text-brand-forest/75">
          For quotes, corporate accounts, or anything that needs more than
          a quick call — drop us a note. We respond within one business hour.
        </p>

        <form
          data-contact-form
          action={`mailto:${EMAIL}`}
          method="post"
          enctype="text/plain"
          novalidate
          class="m-0 space-y-5"
          aria-describedby="contact-form-fallback"
        >
          <!-- Name -->
          <div>
            <label
              for="contact-name"
              class="mb-1.5 block font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/65"
            >
              Full name <span class="text-brand-gold" aria-hidden="true">*</span>
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              required
              aria-required="true"
              class="block w-full border border-brand-forest/15 bg-white px-4 py-3 font-sans text-[0.95rem] text-brand-forest outline-none transition-colors duration-200 placeholder:text-brand-forest/35 focus:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
              placeholder="Jane Doe"
            />
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <!-- Email -->
            <div>
              <label
                for="contact-email"
                class="mb-1.5 block font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/65"
              >
                Email <span class="text-brand-gold" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-email"
                name="email"
                type="email"
                autocomplete="email"
                inputmode="email"
                required
                aria-required="true"
                class="block w-full border border-brand-forest/15 bg-white px-4 py-3 font-sans text-[0.95rem] text-brand-forest outline-none transition-colors duration-200 placeholder:text-brand-forest/35 focus:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
                placeholder="jane@company.com"
              />
            </div>

            <!-- Phone -->
            <div>
              <label
                for="contact-phone"
                class="mb-1.5 block font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/65"
              >
                Phone <span class="font-normal text-brand-forest/40">(optional)</span>
              </label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                class="block w-full border border-brand-forest/15 bg-white px-4 py-3 font-sans text-[0.95rem] tabular-nums text-brand-forest outline-none transition-colors duration-200 placeholder:text-brand-forest/35 focus:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
                placeholder="(206) 555-0123"
              />
            </div>
          </div>

          <!-- Inquiry type -->
          <div>
            <label
              for="contact-inquiry"
              class="mb-1.5 block font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/65"
            >
              Reason for contact <span class="text-brand-gold" aria-hidden="true">*</span>
            </label>
            <select
              id="contact-inquiry"
              name="inquiry"
              required
              aria-required="true"
              class="block w-full appearance-none border border-brand-forest/15 bg-white bg-[length:14px_14px] bg-[right_16px_center] bg-no-repeat px-4 py-3 pr-12 font-sans text-[0.95rem] text-brand-forest outline-none transition-colors duration-200 focus:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
              style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2214%22 height=%2214%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23a37e2c%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><polyline points=%226 9 12 15 18 9%22/></svg>');"
            >
              <option value="" disabled selected>Select one…</option>
              {inquiryTypes.map((type) => (
                <option value={type}>{type}</option>
              ))}
            </select>
          </div>

          <!-- Ride date -->
          <div>
            <label
              for="contact-date"
              class="mb-1.5 block font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/65"
            >
              Ride date <span class="font-normal text-brand-forest/40">(optional)</span>
            </label>
            <input
              id="contact-date"
              name="date"
              type="date"
              class="block w-full border border-brand-forest/15 bg-white px-4 py-3 font-sans text-[0.95rem] tabular-nums text-brand-forest outline-none transition-colors duration-200 placeholder:text-brand-forest/35 focus:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
            />
          </div>

          <!-- Message -->
          <div>
            <label
              for="contact-message"
              class="mb-1.5 block font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/65"
            >
              Message <span class="text-brand-gold" aria-hidden="true">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              aria-required="true"
              class="block w-full resize-y border border-brand-forest/15 bg-white px-4 py-3 font-sans text-[0.95rem] leading-relaxed text-brand-forest outline-none transition-colors duration-200 placeholder:text-brand-forest/35 focus:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
              placeholder="Tell us where you're going, party size, special requests…"
            ></textarea>
          </div>

          <!-- Honeypot (anti-bot) — hidden field that real users won't fill -->
          <div class="absolute -left-[9999px]" aria-hidden="true">
            <label for="contact-website">Website (leave blank)</label>
            <input
              id="contact-website"
              name="website"
              type="text"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <div class="flex flex-col items-stretch gap-3 pt-2 sm:flex-row sm:items-center">
            <button
              type="submit"
              class="inline-flex min-h-[52px] items-center justify-center gap-2 border border-brand-gold bg-brand-gold px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-forest outline-none transition-[background-color,box-shadow] duration-200 hover:bg-brand-gold-soft hover:shadow-[0_12px_28px_-12px_rgba(163,126,44,0.5)] focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne motion-reduce:transition-none"
            >
              Send Message
              <span aria-hidden="true">→</span>
            </button>
            <p
              id="contact-form-fallback"
              class="font-sans text-[0.78rem] leading-snug text-brand-forest/55"
            >
              Opens your mail client with the message pre-filled.
              Prefer something else? <a href="tel:+12065959675" class="font-semibold text-brand-gold underline-offset-2 hover:underline">call (206) 595-9675</a>.
            </p>
          </div>
        </form>
      </div>

      <!-- ── Side card: what happens next ───────────────── -->
      <aside class="relative">
        <div class="sticky top-24 border border-brand-forest/10 bg-white shadow-[0_1px_0_rgba(0,0,0,0.02),0_24px_48px_-32px_rgba(10,35,24,0.18)]">
          <div class="border-b border-brand-forest/8 px-6 py-5">
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
              What happens next
            </p>
            <p class="mt-1 font-display text-lg font-medium leading-tight text-brand-forest">
              After you hit send
            </p>
          </div>

          <ol class="m-0 list-none divide-y divide-brand-forest/8 p-0" role="list">
            <li class="flex items-start gap-4 px-6 py-5">
              <span
                class="inline-flex h-7 w-7 shrink-0 items-center justify-center border border-brand-gold/40 bg-brand-gold/5 font-sans text-[0.72rem] font-semibold tabular-nums text-brand-gold"
                aria-hidden="true"
              >01</span>
              <div>
                <p class="font-display text-base font-medium leading-snug text-brand-forest">
                  Within one business hour
                </p>
                <p class="mt-1 font-sans text-[0.85rem] font-light leading-relaxed text-brand-forest/70">
                  A dispatcher reads your message, pulls fleet availability,
                  and replies from a real address.
                </p>
              </div>
            </li>
            <li class="flex items-start gap-4 px-6 py-5">
              <span
                class="inline-flex h-7 w-7 shrink-0 items-center justify-center border border-brand-gold/40 bg-brand-gold/5 font-sans text-[0.72rem] font-semibold tabular-nums text-brand-gold"
                aria-hidden="true"
              >02</span>
              <div>
                <p class="font-display text-base font-medium leading-snug text-brand-forest">
                  Confirmed quote
                </p>
                <p class="mt-1 font-sans text-[0.85rem] font-light leading-relaxed text-brand-forest/70">
                  Flat-rate pricing tied to your route, vehicle class, and
                  any special requests. No surge, no hidden tolls.
                </p>
              </div>
            </li>
            <li class="flex items-start gap-4 px-6 py-5">
              <span
                class="inline-flex h-7 w-7 shrink-0 items-center justify-center border border-brand-gold/40 bg-brand-gold/5 font-sans text-[0.72rem] font-semibold tabular-nums text-brand-gold"
                aria-hidden="true"
              >03</span>
              <div>
                <p class="font-display text-base font-medium leading-snug text-brand-forest">
                  Lock the booking
                </p>
                <p class="mt-1 font-sans text-[0.85rem] font-light leading-relaxed text-brand-forest/70">
                  Reply to confirm, and dispatch sends a calendar invite +
                  the chauffeur's name twelve hours before pickup.
                </p>
              </div>
            </li>
          </ol>

          <div class="border-t border-brand-forest/8 bg-brand-forest/[0.03] px-6 py-4">
            <p class="font-sans text-[0.78rem] leading-relaxed text-brand-forest/65">
              In a hurry?
              <a
                href="tel:+12065959675"
                class="font-semibold text-brand-gold underline-offset-2 outline-none transition-colors hover:text-brand-gold-soft hover:underline focus-visible:underline focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
              >
                Call (206) 595-9675
              </a>
              — answered 24/7.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-contact-form]');
    if (!form) return;

    form.addEventListener('submit', (e) => {
      // Bail to native mailto if anything looks off — but normally intercept.
      e.preventDefault();

      // Honeypot: real users leave this blank. Bots fill it.
      const honey = /** @type {HTMLInputElement|null} */ (form.querySelector('[name="website"]'));
      if (honey && honey.value.trim() !== '') return;

      // Native validation
      if (!form.reportValidity()) return;

      const data = new FormData(form);
      const name = String(data.get('name') || '').trim();
      const email = String(data.get('email') || '').trim();
      const phone = String(data.get('phone') || '').trim();
      const inquiry = String(data.get('inquiry') || '').trim();
      const date = String(data.get('date') || '').trim();
      const message = String(data.get('message') || '').trim();

      const subject = inquiry
        ? `${inquiry} — ${name}`
        : `Inquiry from ${name}`;

      const bodyLines = [
        `Name: ${name}`,
        `Email: ${email}`,
        phone ? `Phone: ${phone}` : null,
        inquiry ? `Reason: ${inquiry}` : null,
        date ? `Ride date: ${date}` : null,
        '',
        'Message:',
        message,
        '',
        '— Sent from emeraldcitylimos.com/contact',
      ].filter(Boolean);

      const mailto =
        'mailto:client@emeraldcitylimos.com' +
        '?subject=' + encodeURIComponent(subject) +
        '&body=' + encodeURIComponent(bodyLines.join('\n'));

      window.location.href = mailto;
    });
  })();
</script>
