---
/**
 * ContactMethods
 * --------------
 * Three large-tap-target contact cards: phone, email, dispatch hours.
 * Renders at the top of /contact so a visitor who just wants to call or
 * email never has to scroll past a form.
 */
const PHONE_DISPLAY = '(206) 595-9675';
const PHONE_HREF = 'tel:+12065959675';
const EMAIL = 'client@emeraldcitylimos.com';
const EMAIL_HREF = `mailto:${EMAIL}`;

const methods = [
  {
    kind: 'phone' as const,
    label: '24/7 dispatch line',
    value: PHONE_DISPLAY,
    href: PHONE_HREF,
    cta: 'Tap to call',
    detail: 'A human picks up, every hour of every day.',
    iconPath:
      'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z',
  },
  {
    kind: 'email' as const,
    label: 'Reservations email',
    value: EMAIL,
    href: EMAIL_HREF,
    cta: 'Send email',
    detail: 'Most inquiries are answered within one business hour.',
    iconPath:
      'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75',
  },
  {
    kind: 'book' as const,
    label: 'Online booking',
    value: 'Reserve in 60 seconds',
    href: '/book-now',
    cta: 'Open booking',
    detail: 'Flat-rate quote, flight tracking, instant confirmation.',
    iconPath:
      'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5',
  },
];
---

<section
  class="bg-brand-champagne py-12 sm:py-16"
  aria-label="Direct contact methods"
>
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <ul role="list" class="m-0 grid list-none grid-cols-1 gap-4 p-0 md:grid-cols-3 md:gap-5">
      {methods.map((m) => (
        <li class="m-0 p-0">
          <a
            href={m.href}
            class="group relative flex h-full flex-col gap-4 border border-brand-forest/8 bg-white p-6 outline-none transition-[border-color,box-shadow,transform] duration-300 hover:border-brand-gold/45 hover:shadow-[0_24px_48px_-32px_rgba(10,35,24,0.28)] focus-visible:border-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne motion-reduce:transition-none sm:p-7"
            aria-label={`${m.label}: ${m.value}`}
          >
            <span class="inline-flex h-11 w-11 items-center justify-center border border-brand-gold/30 bg-brand-gold/5 text-brand-gold transition-colors duration-300 group-hover:border-brand-gold group-hover:bg-brand-gold group-hover:text-white">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                width="20"
                height="20"
                aria-hidden="true"
              >
                <path d={m.iconPath} />
              </svg>
            </span>

            <div>
              <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
                {m.label}
              </p>
              <p class="mt-1 font-display text-xl font-medium leading-tight tabular-nums text-brand-forest sm:text-[1.4rem]">
                {m.value}
              </p>
            </div>

            <p class="font-sans text-[0.85rem] font-light leading-relaxed text-brand-forest/70">
              {m.detail}
            </p>

            <span class="mt-auto inline-flex items-center gap-1.5 pt-2 font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-gold transition-colors group-hover:text-brand-gold-soft">
              {m.cta}
              <svg
                viewBox="0 0 20 20"
                fill="currentColor"
                class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5"
                aria-hidden="true"
              >
                <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
