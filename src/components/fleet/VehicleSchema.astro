---
/**
 * VehicleSchema
 * -------------
 * Emits per-vehicle Vehicle + Product JSON-LD plus a BreadcrumbList.
 * Crawled by Google for rich results and by AI search engines for
 * vehicle descriptions and capacity facts.
 *
 * BaseLayout emits the site-wide LimousineBusiness schema; this
 * adds the page-specific vehicle entries.
 */
import type { Vehicle } from '@/data/fleet';

interface Props {
  vehicle: Vehicle;
}

const { vehicle } = Astro.props;

const SITE_URL = 'https://emeraldcitylimos.com';
const canonical = `${SITE_URL}${vehicle.href}`;

const vehicleSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Vehicle',
  '@id': `${canonical}#vehicle`,
  name: vehicle.name,
  description: vehicle.description ?? `${vehicle.name} — ${vehicle.category}, ${vehicle.capacityLabel}`,
  url: canonical,
  vehicleSeatingCapacity: vehicle.capacity,
  vehicleConfiguration: vehicle.category,
  brand: {
    '@type': 'Brand',
    name: vehicle.name.split(' ')[0],
  },
};

if (vehicle.imageSrc) {
  const imageSrcStr = typeof vehicle.imageSrc === 'string' ? vehicle.imageSrc : vehicle.imageSrc.src;
  vehicleSchema.image = new URL(imageSrcStr, SITE_URL).href;
}

if (vehicle.specs) {
  if (vehicle.specs.yearRange) {
    vehicleSchema.vehicleModelDate = vehicle.specs.yearRange;
  }
  if (vehicle.specs.drivetrain) {
    vehicleSchema.driveWheelConfiguration = vehicle.specs.drivetrain;
  }
  if (vehicle.specs.transmission) {
    vehicleSchema.vehicleTransmission = vehicle.specs.transmission;
  }
  const engineRow = vehicle.specs.extras?.find((r) => r.label.toLowerCase() === 'engine');
  if (engineRow) {
    vehicleSchema.vehicleEngine = { '@type': 'EngineSpecification', name: engineRow.value };
  }
}

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${canonical}#product`,
  name: `${vehicle.name} Chauffeur Service`,
  description: vehicle.description ?? `Chauffeured ${vehicle.name} (${vehicle.category}) — ${vehicle.capacityLabel}.`,
  category: vehicle.category,
  ...(vehicle.imageSrc ? { image: new URL(typeof vehicle.imageSrc === 'string' ? vehicle.imageSrc : vehicle.imageSrc.src, SITE_URL).href } : {}),
  brand: {
    '@type': 'Brand',
    name: 'Emerald City Limos',
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: `${SITE_URL}/book-now`,
    priceCurrency: 'USD',
    seller: {
      '@type': 'LimousineBusiness',
      name: 'Emerald City Limos',
      '@id': SITE_URL,
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Fleet', item: `${SITE_URL}/fleet` },
    { '@type': 'ListItem', position: 3, name: vehicle.name, item: canonical },
  ],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(vehicleSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(productSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
