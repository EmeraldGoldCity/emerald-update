---
/**
 * VehicleIntro
 * ------------
 * Body intro block on the vehicle detail page. Pairs the long-form
 * description with a compact stat strip (category, capacity, drivetrain)
 * and a "Best For" tag row, plus a CTA cluster for conversion.
 */
import type { Vehicle } from '@/data/fleet';

interface Props {
  vehicle: Vehicle;
}

const { vehicle } = Astro.props;

const PHONE_DISPLAY = '(206) 595-9675';
const PHONE_HREF = 'tel:+12065959675';

const statRows = [
  { label: 'Capacity', value: vehicle.capacityLabel },
  ...(vehicle.specs?.drivetrain
    ? [{ label: 'Drivetrain', value: vehicle.specs.drivetrain }]
    : []),
  ...(vehicle.specs?.yearRange
    ? [{ label: 'Model years', value: vehicle.specs.yearRange }]
    : []),
];
---

<section
  class="bg-brand-champagne py-16 sm:py-20 lg:py-24"
  aria-labelledby={`intro-${vehicle.id}`}
>
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_1fr] lg:gap-16">

      <!-- ── Copy column ───────────────────────────────────── -->
      <div class="flex flex-col">
        <div class="mb-4 flex items-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            {vehicle.category}
          </p>
        </div>

        <h2
          id={`intro-${vehicle.id}`}
          class="mb-6 font-display font-light leading-[1.08] text-brand-forest"
          style="font-size: clamp(1.85rem, 3.4vw, 2.5rem); letter-spacing: -0.01em;"
        >
          The {vehicle.name},
          <em class="italic text-brand-gold">in detail.</em>
        </h2>

        {vehicle.description && (
          <p class="font-sans text-[0.98rem] font-light leading-[1.8] text-brand-forest/85 sm:text-[1.02rem]">
            {vehicle.description}
          </p>
        )}

        {vehicle.descriptionExtended && (
          <p class="mt-5 border-l-2 border-brand-gold/30 pl-4 font-sans text-[0.92rem] font-light italic leading-[1.75] text-brand-forest/70">
            {vehicle.descriptionExtended}
          </p>
        )}

        {vehicle.bestFor.length > 0 && (
          <div class="mt-7">
            <p class="mb-3 font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-forest/55">
              Best for
            </p>
            <ul role="list" class="m-0 flex list-none flex-wrap gap-1.5 p-0">
              {vehicle.bestFor.map((tag) => (
                <li class="border border-brand-forest/12 bg-white px-2.5 py-1 font-sans text-[0.72rem] font-medium leading-tight text-brand-forest/80">
                  {tag}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- CTA cluster -->
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="https://customer.moovs.app/a1-charters-1/new/info"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center bg-brand-gold px-5 font-sans text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-brand-forest outline-none shadow-[0_2px_0_rgba(0,0,0,0.08)] transition-[background-color,box-shadow] duration-200 hover:bg-brand-gold-soft hover:shadow-[0_6px_20px_-6px_rgba(163,126,44,0.55)] focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne motion-reduce:transition-none"
            aria-label={`Reserve the ${vehicle.name}`}
          >
            Reserve this Vehicle
            <svg
              viewBox="0 0 20 20"
              fill="currentColor"
              class="ml-2 h-3 w-3"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href={PHONE_HREF}
            class="inline-flex h-11 items-center gap-2 px-2 font-sans text-sm font-semibold tabular-nums text-brand-forest outline-none transition-colors duration-200 hover:text-brand-gold focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne motion-reduce:transition-none"
            aria-label={`Call Emerald City Limos at ${PHONE_DISPLAY}, available 24 hours`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4 text-brand-gold"
              aria-hidden="true"
            >
              <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            {PHONE_DISPLAY}
          </a>
        </div>
      </div>

      <!-- ── Stat card ─────────────────────────────────────── -->
      <aside class="relative">
        <div class="relative border border-brand-forest/10 bg-white shadow-[0_1px_0_rgba(0,0,0,0.02),0_24px_48px_-32px_rgba(10,35,24,0.18)]">

          <div class="border-b border-brand-forest/8 px-5 py-4 sm:px-6">
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
              At a Glance
            </p>
            <p class="font-display text-base font-medium leading-tight text-brand-forest">
              {vehicle.name}
            </p>
          </div>

          <dl class="m-0 divide-y divide-brand-forest/8 p-0">
            {statRows.map((row) => (
              <div class="flex items-baseline justify-between gap-6 px-5 py-4 sm:px-6 sm:py-5">
                <dt class="font-sans text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-brand-forest/55">
                  {row.label}
                </dt>
                <dd class="text-right font-sans text-[0.92rem] font-medium leading-snug tabular-nums text-brand-forest">
                  {row.value}
                </dd>
              </div>
            ))}
          </dl>

          <div class="border-t border-brand-forest/8 bg-brand-forest/[0.03] px-5 py-4 sm:px-6">
            <p class="font-sans text-[0.72rem] leading-relaxed text-brand-forest/65">
              Pricing varies by route and duration —
              <a
                href="https://customer.moovs.app/a1-charters-1/new/info"
                target="_blank"
                rel="noopener noreferrer"
                class="font-semibold text-brand-gold underline-offset-2 outline-none transition-colors hover:text-brand-gold-soft hover:underline focus-visible:underline focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-champagne"
              >
                request a quote
              </a>.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
