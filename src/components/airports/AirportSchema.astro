---
/**
 * AirportSchema
 * -------------
 * Emits per-airport Airport, Service (chauffeur service to/from the
 * airport), FAQPage, and BreadcrumbList JSON-LD. Crawled by Google for
 * rich results and by AI search engines for airport facts and FAQ
 * snippets.
 *
 * BaseLayout emits the site-wide LimousineBusiness schema; this adds
 * the page-specific entries.
 */
import type { Airport } from '@/data/airports';

interface Props {
  airport: Airport;
}

const { airport } = Astro.props;

const SITE_URL = 'https://emeraldcitylimos.com';
const canonical = `${SITE_URL}${airport.href}`;

const airportSchema = {
  '@context': 'https://schema.org',
  '@type': 'Airport',
  '@id': `${canonical}#airport`,
  name: airport.fullName,
  alternateName: airport.name,
  iataCode: airport.code,
  url: canonical,
  address: {
    '@type': 'PostalAddress',
    streetAddress: airport.address,
    addressLocality: 'Seattle',
    addressRegion: 'WA',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: airport.coordinates.lat,
    longitude: airport.coordinates.lng,
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: `${airport.code} Airport Transfer Service`,
  description: airport.heroSupporting,
  url: canonical,
  serviceType: 'Airport Transportation',
  areaServed: {
    '@type': 'City',
    name: 'Seattle',
    sameAs: 'https://en.wikipedia.org/wiki/Seattle',
  },
  provider: {
    '@type': 'LimousineBusiness',
    name: 'Emerald City Limos',
    '@id': SITE_URL,
    url: SITE_URL,
    telephone: '+1-206-595-9675',
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: 'https://customer.moovs.app/a1-charters-1/new/info',
    priceCurrency: 'USD',
  },
};

const faqSchema =
  airport.faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        '@id': `${canonical}#faq`,
        mainEntity: airport.faqs.map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: { '@type': 'Answer', text: faq.answer },
        })),
      }
    : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Airports', item: `${SITE_URL}/airport` },
    { '@type': 'ListItem', position: 3, name: airport.name, item: canonical },
  ],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(airportSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
{faqSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
