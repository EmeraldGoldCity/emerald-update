---
/**
 * AirportRoutes
 * -------------
 * Popular routes table for an airport detail page. Renders city → airport
 * rows with distance, drive time, and (optional) starting price. Disclaimer
 * row renders only when at least one route exposes a price.
 */
import type { Airport } from '@/data/airports';

interface Props {
  airport: Airport;
}

const { airport } = Astro.props;

if (airport.popularRoutes.length === 0) return null;

const hasPricing = airport.popularRoutes.some(
  (r) => typeof r.startingPriceUSD === 'number'
);
---

<section
  class="bg-brand-forest py-16 text-brand-champagne sm:py-20 lg:py-24"
  aria-labelledby={`routes-${airport.slug}`}
>
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">

    <div class="mb-10 flex flex-col gap-3 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="mb-3 flex items-center gap-3">
          <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
            Popular Routes
          </p>
        </div>
        <h2
          id={`routes-${airport.slug}`}
          class="font-display font-light leading-[1.1] text-white"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          From your city
          <em class="italic text-brand-gold-soft">to {airport.code}.</em>
        </h2>
      </div>
      <a
        href="/book-now?intent=quote"
        class="inline-flex w-fit items-center gap-1.5 border-b border-brand-gold-soft/50 pb-1 font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft outline-none transition-colors hover:border-brand-gold-soft hover:text-white focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
      >
        Different city? Get a quote
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>

    <ul
      role="list"
      class="m-0 grid list-none grid-cols-1 gap-px overflow-hidden border border-white/8 bg-white/8 p-0 md:grid-cols-2 lg:grid-cols-3"
    >
      {airport.popularRoutes.map((route) => (
        <li class="flex h-full flex-col gap-3 bg-brand-forest px-5 py-5 sm:px-6 sm:py-6">
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-display text-lg font-medium leading-tight text-white">
              {route.from} <span class="text-brand-gold-soft/70">→</span> {airport.code}
            </h3>
            {typeof route.startingPriceUSD === 'number' && (
              <span class="inline-flex shrink-0 items-center border border-brand-gold-soft/40 bg-brand-gold-soft/10 px-2 py-1 font-sans text-[0.72rem] font-semibold tabular-nums text-brand-gold-soft">
                From ${route.startingPriceUSD}
              </span>
            )}
          </div>
          <dl class="m-0 flex items-baseline gap-5 p-0">
            <div class="flex items-baseline gap-1.5">
              <dt class="font-sans text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-white/45">
                Distance
              </dt>
              <dd class="font-sans text-[0.85rem] font-medium tabular-nums text-white">
                {route.distanceMiles} mi
              </dd>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dt class="font-sans text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-white/45">
                Drive
              </dt>
              <dd class="font-sans text-[0.85rem] font-medium tabular-nums text-white">
                {route.driveTime}
              </dd>
            </div>
          </dl>
        </li>
      ))}
    </ul>

    {hasPricing && (
      <p class="mt-5 text-center font-sans text-[0.72rem] uppercase tracking-[0.16em] text-white/45">
        Prices are starting-from estimates. Exact quote provided at booking.
      </p>
    )}
  </div>
</section>
