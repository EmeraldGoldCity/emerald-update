---
/**
 * ExoticFleetSection
 * ------------------
 * Full grid of all exotic vehicles on the /services/car-exotics page.
 * Each card deep-links to /exotics/[slug] for the full detail page
 * with carousel, specs, and booking CTAs.
 *
 * Reuses the same dark-forest card aesthetic as ServiceFleetMatch
 * but renders every exotic vehicle — not a curated subset.
 */
import { exoticFleet } from '@/data/exotics';
---

<section
  class="bg-brand-forest py-16 text-brand-champagne sm:py-20 lg:py-24"
  aria-labelledby="exotic-fleet-heading"
>
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">

    <!-- Section header -->
    <div class="mb-10 flex flex-col gap-4 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="mb-3 flex items-center gap-3">
          <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
            Exotic Fleet
          </p>
        </div>
        <h2
          id="exotic-fleet-heading"
          class="font-display font-light leading-[1.1] text-white"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Every exotic,
          <em class="italic text-brand-gold-soft">available now</em>
        </h2>
      </div>

      <!-- Availability note -->
      <p class="max-w-xs font-sans text-[0.75rem] leading-relaxed text-white/55 sm:text-right">
        All vehicles available chauffeur-driven or as a verified self-drive rental.
        Delivered to your location.
      </p>
    </div>

    <!-- Vehicle grid -->
    <ul
      role="list"
      class="m-0 grid list-none grid-cols-1 gap-5 p-0 sm:grid-cols-2 lg:grid-cols-3"
    >
      {exoticFleet.map((vehicle) => (
        <li class="m-0 p-0">
          <a
            href={vehicle.href}
            class="group relative flex h-full flex-col overflow-hidden border-l-2 border-brand-gold/60 bg-white/[0.04] outline-none ring-1 ring-white/8 transition-[border-color,background-color,box-shadow] duration-300 hover:border-brand-gold-soft hover:bg-white/[0.07] hover:shadow-[0_24px_48px_-32px_rgba(0,0,0,0.6)] focus-visible:border-brand-gold-soft focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
            aria-label={`Explore the ${vehicle.name} — ${vehicle.category}`}
          >
            <!-- Image area -->
            <div class="relative aspect-[4/3] w-full overflow-hidden bg-brand-forest-deep">
              {vehicle.imageSrc ? (
                <img
                  src={typeof vehicle.imageSrc === 'string' ? vehicle.imageSrc : (vehicle.imageSrc as any).src}
                  alt={vehicle.imageAlt}
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="600"
                  class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                  <span
                    class="absolute inset-0"
                    style="background: radial-gradient(ellipse 60% 55% at center, var(--color-brand-gold-soft) 0%, transparent 70%); opacity: 0.16;"
                  ></span>
                  <span class="font-display text-2xl italic text-brand-gold-soft/70">
                    {vehicle.category}
                  </span>
                </div>
              )}

              <!-- Category badge -->
              <span
                class="absolute left-3 top-3 inline-flex items-center gap-1.5 bg-brand-forest/85 px-2 py-1 font-sans text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-brand-gold-soft backdrop-blur-sm"
              >
                {vehicle.category}
              </span>

              <!-- Gallery indicator: show how many photos -->
              {vehicle.gallery && vehicle.gallery.length > 1 && (
                <span
                  class="absolute bottom-3 right-3 inline-flex items-center gap-1 bg-brand-forest-deep/80 px-2 py-0.5 font-sans text-[0.6rem] font-semibold uppercase tracking-[0.14em] text-white/70 backdrop-blur-sm"
                  aria-label={`${vehicle.gallery.length} photos`}
                >
                  <svg viewBox="0 0 16 16" fill="currentColor" class="h-2.5 w-2.5 text-brand-gold-soft" aria-hidden="true">
                    <path d="M2 4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4Zm10.5 0a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v4.56l1.97-1.97a.75.75 0 0 1 1.06 0L9 8.06l1.22-1.22a.75.75 0 0 1 1.06 0l1.22 1.22V4Z"/>
                  </svg>
                  {vehicle.gallery.length}
                </span>
              )}
            </div>

            <!-- Card body -->
            <div class="flex flex-1 flex-col gap-3 p-5">
              <div>
                <h3 class="font-display text-lg font-medium leading-tight text-white">
                  {vehicle.name}
                </h3>
                <p class="mt-1 font-sans text-[0.75rem] font-medium tabular-nums text-brand-gold-soft">
                  {vehicle.capacityLabel}
                </p>
              </div>

              <!-- Top 3 features -->
              <ul role="list" class="m-0 list-none space-y-1 p-0">
                {vehicle.features.slice(0, 3).map((feature) => (
                  <li class="flex items-start gap-2 font-sans text-[0.78rem] leading-snug text-white/70">
                    <span class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-brand-gold-soft" aria-hidden="true"></span>
                    {feature}
                  </li>
                ))}
              </ul>

              <!-- Availability badge + CTA row -->
              <div class="mt-auto flex items-center justify-between gap-3 pt-1">
                <span class="inline-flex items-center gap-1 rounded-full border border-brand-gold/25 px-2.5 py-1 font-sans text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-brand-gold-soft">
                  Chauffeur · Self-Drive
                </span>
                <span class="inline-flex items-center gap-1.5 font-sans text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft transition-colors group-hover:text-white">
                  Explore
                  <svg
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5"
                    aria-hidden="true"
                  >
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
