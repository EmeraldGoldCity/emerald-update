---
import BaseLayout from './BaseLayout.astro';
import { Navigation } from '@/components/react/Navigation';
import { Footer } from '@/components/react/Footer';
// import AnnouncementBanner from '@/components/shared/AnnouncementBanner.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>

  <!-- Skip to Main Content Link -->
  <a href="#main-content" class="skip-link">
    Skip to main content
  </a>

  <!-- FIFA World Cup 2026 announcement bar (self-dismisses after 2026-07-19) -->
  <!-- <AnnouncementBanner /> -->

  <!-- Header with Navigation -->
  <Navigation client:idle />

  <!-- Main Content -->
  <main id="main-content" role="main">
    <slot />
  </main>

  <!-- Footer -->
  <Footer />
</BaseLayout>