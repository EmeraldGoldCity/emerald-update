---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
import { getVehicle } from '@/data/fleet';
import concertsImg from '@/assets/images/events/concerts.jpg';

import type { Vehicle } from '@/data/fleet';

const concertFleet = ['escalade-esv', 'sprinter', 'navigator-l']
  .map(getVehicle)
  .filter((v): v is Vehicle => v != null);

const SITE_URL = 'https://emeraldcitylimos.com';
const canonical = `${SITE_URL}/events/concerts-seattle`;

/* ── Seattle concert venues ──────────────────────────────────────────────── */
const venues = [
  {
    name: 'Climate Pledge Arena',
    location: 'Seattle Center',
    capacity: '17,000+',
    note: 'NHL · NBA · major tours',
  },
  {
    name: 'Lumen Field',
    location: 'SoDo',
    capacity: '70,000+',
    note: 'Stadium concerts',
  },
  {
    name: 'The Paramount Theatre',
    location: 'Downtown',
    capacity: '2,800',
    note: 'Mid-size shows',
  },
  {
    name: 'Moore Theatre',
    location: 'Downtown',
    capacity: '1,800',
    note: 'Intimate shows',
  },
  {
    name: 'Chateau Ste. Michelle',
    location: 'Woodinville',
    capacity: '4,000',
    note: 'Summer amphitheater',
  },
];

/* ── Benefits ────────────────────────────────────────────────────────────── */
const benefits = [
  {
    title: 'Door-to-Door Convenience',
    description: 'Dropped at the venue entrance, picked up at a pre-arranged exit point — no hunting for rideshares on the street after the show.',
    iconPath: 'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  },
  {
    title: 'No Surge After the Show',
    description: 'Every rideshare app spikes when 20,000 people hit it simultaneously. Your fare is locked at booking — no matter what the apps show when the encore ends.',
    iconPath: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Multi-Venue Nights',
    description: 'Pre-show dinner, the concert, and the after-party — one booking covers the full evening. Your chauffeur follows your itinerary start to finish.',
    iconPath: 'M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z',
  },
  {
    title: 'Groups Welcome',
    description: 'Sprinter vans keep your crew of up to 14 together from start to finish — no splitting into multiple cars, no waiting for the group to reassemble.',
    iconPath: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
  },
  {
    title: 'Last-Minute Availability',
    description: 'We monitor major show announcements and keep vehicles available for late bookings. Check availability any time — we\'ll tell you honestly what\'s open.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Trusted for Major Tours',
    description: 'Our chauffeurs know the load-in and load-out logistics at Climate Pledge Arena, Lumen Field, The Paramount, and Moore Theatre — no guessing on the night.',
    iconPath: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
  },
];

/* ── FAQs ─────────────────────────────────────────────────────────────────── */
const faqs = [
  {
    question: 'Which Seattle concert venues do you serve?',
    answer: 'We serve all major Seattle-area concert venues including Climate Pledge Arena (Seattle Center), Lumen Field (SoDo), The Paramount Theatre (Downtown), Moore Theatre (Downtown), Chateau Ste. Michelle Winery (Woodinville), WaMu Theater, and Benaroya Hall. If your venue isn\'t listed, contact us — we cover the full metro area.',
  },
  {
    question: 'How early should I book transportation for a major stadium concert?',
    answer: 'For stadium shows at Climate Pledge Arena or Lumen Field — especially major touring artists — we recommend booking at least 1–2 weeks out. The biggest tours announced months in advance can fill premium vehicles within days of the on-sale. The sooner you book, the better your vehicle selection and time-slot flexibility.',
  },
  {
    question: 'Can you accommodate a group coming from different parts of the Seattle metro?',
    answer: 'Yes. We handle multi-stop pickup routes across Seattle, Bellevue, Kirkland, Redmond, and the Eastside. Provide all pickup addresses when you book and we design the route. Our Sprinter van holds up to 14 passengers comfortably and keeps the entire group together for the full night.',
  },
  {
    question: 'What if the concert runs long or there is an encore?',
    answer: 'Your flat-rate fare covers the full event regardless of how long it runs. Our chauffeurs monitor event status and are staged near the venue for your exit — whether the show ends on time or goes 45 minutes long with a three-song encore. There is no extra charge for wait time.',
  },
  {
    question: 'Do you offer meet-and-greet or VIP drop-off options?',
    answer: 'Yes. We work with your VIP access details and coordinate drop-off at artist entrance points, VIP lot access gates, and pre-show dinners. Let us know the specifics of your VIP package at booking and we\'ll align the logistics accordingly. We\'ve handled artist and executive transport at major Seattle venues and understand the access protocols.',
  },
  {
    question: 'Can I book the same vehicle for a pre-show dinner and post-show pickup?',
    answer: 'Absolutely — this is one of the most common requests we receive for concert nights. Book the vehicle for the full evening: pre-show dinner pickup, venue drop-off, and post-show return. The chauffeur waits in the interim at a designated staging area and is ready when the show ends. One booking, one fare, the entire night.',
  },
];

/* ── Structured data ─────────────────────────────────────────────────────── */
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: 'Concert Transportation Seattle',
  description: 'Luxury chauffeur service for concerts and live events in Seattle. Climate Pledge Arena, Lumen Field, The Paramount, Moore Theatre, and Chateau Ste. Michelle. Flat-rate pricing, no surge.',
  url: canonical,
  serviceType: 'Event Transportation',
  areaServed: {
    '@type': 'City',
    name: 'Seattle',
    sameAs: 'https://en.wikipedia.org/wiki/Seattle',
  },
  provider: {
    '@type': 'LimousineBusiness',
    name: 'Emerald City Limos',
    '@id': SITE_URL,
    url: SITE_URL,
    telephone: '+1-206-595-9675',
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: 'https://customer.moovs.app/a1-charters-1/new/info',
    priceCurrency: 'USD',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',             item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Events',           item: `${SITE_URL}/events` },
    { '@type': 'ListItem', position: 3, name: 'Concerts Seattle', item: canonical },
  ],
};
---

<MainLayout
  title="Concert Transportation Seattle | Climate Pledge Arena & More | Emerald City Limos"
  description="Luxury concert transportation in Seattle. Climate Pledge Arena, Lumen Field, The Paramount, Moore Theatre. Flat-rate pricing, no post-show surge, groups welcome."
  keywords="concert transportation seattle, climate pledge arena car service, lumen field concert limo, seattle concert chauffeur, concert ride service seattle, paramount theatre transportation seattle"
  canonical={canonical}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <PageHero
    eyebrow="Concerts & Live Events · Seattle"
    headline="Your Night Out,"
    headlineAccent="Without the Hassle."
    supporting="Climate Pledge Arena, Lumen Field, and The Paramount book some of the biggest tours in the world. We handle the before and after so the night is only about the show."
    ctaPrimary={{ label: 'Book Concert Transport', href: 'https://customer.moovs.app/a1-charters-1/new/info', id: 'cta-concerts-hero-primary' }}
    image={{ src: concertsImg, alt: 'Live concert event in Seattle — luxury transport to Seattle venues' }}
    size="page"
    id="concerts-hero"
    breadcrumbs={[
      { label: 'Home',             href: '/' },
      { label: 'Events',           href: '/events' },
      { label: 'Concerts Seattle' },
    ]}
  />

  <!-- ── Trust strip ───────────────────────────────────────────────────── -->
  <TrustStrip />

  <!-- ── Seattle venues ────────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-forest-deep py-16 sm:py-20 lg:py-24"
    aria-labelledby="concerts-venues-heading"
  >
    <!-- Radial gold glow -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse 60% 70% at 50% 50%, rgba(163,126,44,0.12) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.4), transparent);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.25), transparent);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">

      <!-- Header -->
      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold-soft/60" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
            Seattle & Surroundings
          </p>
          <span class="h-px w-8 bg-brand-gold-soft/60" aria-hidden="true"></span>
        </div>
        <h2
          id="concerts-venues-heading"
          class="font-display font-light leading-[1.1] text-white"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Seattle's Premier
          <em class="italic text-brand-gold-soft">Concert Venues.</em>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl font-sans text-[0.88rem] font-light leading-relaxed text-white/55">
          From intimate theatres to 70,000-seat stadiums, we serve every major concert venue in the
          Seattle metro. Our chauffeurs know the logistics at each one — arrival gates, staging areas,
          and the fastest post-show exits.
        </p>
      </div>

      <!-- Venue cards -->
      <ul
        role="list"
        class="m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2 lg:grid-cols-3"
        aria-label="Seattle concert venues served"
      >
        {venues.map((venue) => (
          <li class="flex flex-col gap-2 border border-white/10 bg-white/[0.04] px-5 py-5 transition-colors duration-300 hover:bg-white/[0.07]">
            <div class="flex items-start justify-between gap-3">
              <span class="font-display text-[1rem] font-medium leading-snug text-white">
                {venue.name}
              </span>
              <span class="shrink-0 font-sans text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-brand-gold-soft/70">
                {venue.capacity}
              </span>
            </div>
            <span class="font-sans text-[0.78rem] font-light text-white/40">
              {venue.location} &mdash; {venue.note}
            </span>
          </li>
        ))}
      </ul>

      <p class="mt-8 text-center font-sans text-[0.78rem] font-light text-white/40">
        Not seeing your venue? We serve all Seattle-area concert halls, amphitheaters, and club venues — contact us for any show.
      </p>
    </div>
  </section>

  <!-- ── Why book with us ───────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="concerts-benefits-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/25 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.15fr] lg:gap-16 xl:gap-20">

        <!-- Copy -->
        <div class="flex flex-col">
          <div class="mb-4 flex items-center gap-3">
            <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
              Why Emerald City Limos
            </p>
          </div>
          <h2
            id="concerts-benefits-heading"
            class="mb-6 font-display font-light leading-[1.08] text-brand-forest"
            style="font-size: clamp(1.85rem, 3.4vw, 2.5rem); letter-spacing: -0.01em;"
          >
            Concert night without
            <em class="italic text-brand-gold">the post-show scramble.</em>
          </h2>
          <p class="font-sans text-[0.98rem] font-light leading-[1.8] text-brand-forest/80 sm:text-[1.02rem]">
            The show ends and 15,000 people hit their phones at the same moment — rideshare prices
            triple and wait times balloon past an hour. We position your car near the exit before the
            encore ends. You walk out and your ride is there.
          </p>
          <p class="mt-5 border-l-2 border-brand-gold/30 pl-4 font-sans text-[0.92rem] font-light italic leading-[1.75] text-brand-forest/65">
            Pre-show dinner, the concert, and the after-party can all be handled in a single booking — your chauffeur runs the full evening.
          </p>
        </div>

        <!-- Benefits grid -->
        <ul
          class="m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2"
          aria-label="Concert transportation benefits"
        >
          {benefits.map((benefit) => (
            <li class="group relative flex flex-col gap-3 border border-brand-forest/8 bg-white p-5 transition-colors duration-300 hover:border-brand-gold/45">
              <span class="inline-flex h-10 w-10 items-center justify-center bg-brand-gold/10 text-brand-gold transition-colors duration-300 group-hover:bg-brand-gold group-hover:text-white">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="18"
                  height="18"
                  aria-hidden="true"
                >
                  <path d={benefit.iconPath} />
                </svg>
              </span>
              <h3 class="font-display text-base font-medium leading-snug text-brand-forest">
                {benefit.title}
              </h3>
              <p class="font-sans text-[0.82rem] leading-relaxed text-brand-forest/70">
                {benefit.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────────────────────────────── -->
  <section
    class="relative bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="concerts-how-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/25 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            How It Works
          </p>
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        </div>
        <h2
          id="concerts-how-heading"
          class="font-display font-light leading-[1.1] text-brand-forest"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Three steps to a
          <em class="italic text-brand-gold">perfect concert night.</em>
        </h2>
      </div>

      <ol
        class="m-0 grid list-none grid-cols-1 gap-px p-0 border border-brand-forest/8 bg-brand-forest/8 sm:grid-cols-3"
        aria-label="Concert transport booking process"
      >
        {[
          {
            step: '01',
            title: 'Book Your Night',
            body: 'Choose your vehicle, enter your show details and pickup address, and lock in your flat rate — pre-show dinner, the concert, and the return all in one booking.',
          },
          {
            step: '02',
            title: 'We Stage for the Show',
            body: 'Your chauffeur reviews the venue logistics, monitors the show schedule, and positions near the exit before the encore ends.',
          },
          {
            step: '03',
            title: 'Walk Out, Ride Home',
            body: 'You exit the venue and your car is there. No apps, no surge, no 40-minute wait in a crowd. Door to door, start to finish.',
          },
        ].map(({ step, title, body }) => (
          <li class="flex flex-col gap-4 bg-white p-6 sm:p-8">
            <span
              class="font-display text-[3rem] font-light leading-none text-brand-gold/25"
              aria-hidden="true"
            >
              {step}
            </span>
            <h3 class="font-display text-[1.15rem] font-medium leading-snug text-brand-forest">
              {title}
            </h3>
            <p class="font-sans text-[0.85rem] leading-relaxed text-brand-forest/70">
              {body}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Fleet ───────────────────────────────────────────────────────────── -->
  <section
    class="bg-brand-forest py-16 text-brand-champagne sm:py-20 lg:py-24"
    aria-labelledby="concerts-fleet-heading"
  >
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 flex flex-col gap-4 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="mb-3 flex items-center gap-3">
            <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
              Recommended Fleet
            </p>
          </div>
          <h2
            id="concerts-fleet-heading"
            class="font-display font-light leading-[1.1] text-white"
            style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
          >
            The right vehicle for
            <em class="italic text-brand-gold-soft">every concert night.</em>
          </h2>
        </div>
        <a
          href="/fleet"
          class="inline-flex w-fit items-center gap-1.5 border-b border-brand-gold-soft/50 pb-1 font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft outline-none transition-colors hover:border-brand-gold-soft hover:text-white focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
        >
          View full fleet
          <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <ul
        role="list"
        class="m-0 grid list-none grid-cols-1 gap-5 p-0 md:grid-cols-2 lg:grid-cols-3"
      >
        {concertFleet.map((vehicle) => (
          <li class="m-0 p-0">
            <a
              href={vehicle.href}
              class="group relative flex h-full flex-col overflow-hidden border-l-2 border-brand-gold/60 bg-white/[0.04] outline-none ring-1 ring-white/8 transition-[border-color,background-color,box-shadow] duration-300 hover:border-brand-gold-soft hover:bg-white/[0.07] hover:shadow-[0_24px_48px_-32px_rgba(0,0,0,0.6)] focus-visible:border-brand-gold-soft focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
              aria-label={`View ${vehicle.name} on the fleet page`}
            >
              <div class="relative aspect-[4/3] w-full overflow-hidden bg-brand-forest-deep">
                {vehicle.imageSrc ? (
                  <img
                    src={typeof vehicle.imageSrc === 'string' ? vehicle.imageSrc : vehicle.imageSrc!.src}
                    alt={vehicle.imageAlt}
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="600"
                    class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                    <span
                      class="absolute inset-0"
                      style="background: radial-gradient(ellipse 60% 55% at center, var(--color-brand-gold-soft) 0%, transparent 70%); opacity: 0.16;"
                    ></span>
                    <span class="font-display text-2xl italic text-brand-gold-soft/70">
                      {vehicle.category}
                    </span>
                  </div>
                )}
                <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 bg-brand-forest/85 px-2 py-1 font-sans text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-brand-gold-soft backdrop-blur-sm">
                  {vehicle.category}
                </span>
              </div>

              <div class="flex flex-1 flex-col gap-3 p-5">
                <h3 class="font-display text-lg font-medium leading-tight text-white">
                  {vehicle.name}
                </h3>
                <p class="font-sans text-[0.78rem] font-medium tabular-nums text-brand-gold-soft">
                  {vehicle.capacityLabel}
                </p>
                <ul role="list" class="m-0 list-none space-y-1 p-0">
                  {vehicle.features.slice(0, 3).map((feature) => (
                    <li class="flex items-start gap-2 font-sans text-[0.78rem] leading-snug text-white/70">
                      <span class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-brand-gold-soft" aria-hidden="true"></span>
                      {feature}
                    </li>
                  ))}
                </ul>
                <span class="mt-auto inline-flex items-center gap-1.5 font-sans text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft transition-colors group-hover:text-white">
                  View vehicle
                  <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────── -->
  <section
    class="bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="concerts-faq-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/15 to-transparent"
      aria-hidden="true"
    ></div>
    <div class="mx-auto max-w-4xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            Common Questions
          </p>
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        </div>
        <h2
          id="concerts-faq-heading"
          class="font-display font-light leading-[1.1] text-brand-forest"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Concert transport,
          <em class="italic text-brand-gold">answered.</em>
        </h2>
      </div>

      <ul role="list" class="m-0 list-none space-y-3 p-0">
        {faqs.map((faq, index) => (
          <li class="m-0 p-0">
            <details
              class="group relative border border-brand-forest/8 bg-white transition-[border-color,box-shadow] duration-300 open:border-brand-gold/40 open:shadow-[0_18px_36px_-28px_rgba(10,35,24,0.25)] hover:border-brand-gold/30"
              name="concerts-faq"
            >
              <summary class="flex cursor-pointer items-start gap-4 px-5 py-4 outline-none transition-colors focus-visible:bg-brand-gold/[0.04] sm:px-6 sm:py-5 [&::-webkit-details-marker]:hidden [&::marker]:hidden">
                <span
                  class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center font-sans text-[0.7rem] font-semibold tabular-nums text-brand-gold"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="flex-1 font-display text-[1.05rem] font-medium leading-snug text-brand-forest sm:text-[1.12rem]">
                  {faq.question}
                </span>
                <span
                  class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center text-brand-gold transition-transform duration-300 group-open:rotate-45"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                    <path d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                </span>
              </summary>
              <div class="px-5 pb-5 pl-[3.5rem] sm:px-6 sm:pb-6 sm:pl-[3.75rem]">
                <p class="font-sans text-[0.92rem] font-light leading-[1.75] text-brand-forest/75">
                  {faq.answer}
                </p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Closing CTA ────────────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-forest-deep py-16 text-brand-champagne sm:py-20 lg:py-24"
    aria-labelledby="concerts-cta-heading"
  >
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 80% 50%, rgba(163,126,44,0.16) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.45), transparent);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.3), transparent);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-4xl px-6 text-center sm:px-8 lg:px-12">
      <div class="mb-3 flex items-center justify-center gap-3">
        <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
        <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
          Book for Your Show
        </p>
        <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
      </div>

      <h2
        id="concerts-cta-heading"
