---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
import { getVehicle } from '@/data/fleet';
import gameDayImg from '@/assets/images/services/gameday/game-day.png';

import type { Vehicle } from '@/data/fleet';

const marinersFleet = ['escalade-esv', 'sprinter', 'navigator-l']
  .map(getVehicle)
  .filter((v): v is Vehicle => v != null);

const SITE_URL = 'https://emeraldcitylimos.com';
const canonical = `${SITE_URL}/events/mariners-game-day`;

/* ── Benefits ────────────────────────────────────────────────────────────── */
const benefits = [
  {
    title: 'First-Pitch Punctual',
    description: 'We time arrival for batting practice or first pitch, your call — our chauffeurs factor in SoDo traffic and build in the right buffer.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Flat-Rate, No Hidden Fees',
    description: 'No parking ($40+ per game at nearby lots), no surge pricing, no surprises. Your fare is locked at booking — full stop.',
    iconPath: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Extra Innings, No Problem',
    description: 'Flat-rate pricing covers however long the game runs — whether it ends in nine innings or goes deep into extras.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Groups of Any Size',
    description: 'SUVs for families and small groups, Sprinter vans for corporate suites and large parties — one booking keeps everyone together.',
    iconPath: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
  },
  {
    title: 'SoDo Closure Routing',
    description: 'Game-day street closures and pedestrian zones are factored into every pickup and drop-off — no last-minute detours.',
    iconPath: 'M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z',
  },
  {
    title: 'Season Package Inquiries',
    description: 'Attending 10 or more home games this season? Ask about multi-booking options — we hold your preferred vehicle and time slots across the schedule.',
    iconPath: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5',
  },
];

/* ── FAQs ─────────────────────────────────────────────────────────────────── */
const faqs = [
  {
    question: 'How far is T-Mobile Park from Seattle-Tacoma Airport?',
    answer: 'T-Mobile Park is approximately 14 miles from Seattle-Tacoma International Airport — typically a 25–35 minute drive under normal conditions. On game days, SoDo traffic builds early, especially for evening games. A private car eliminates the parking search and gives you a direct, predictable ride from baggage claim to the stadium gates.',
  },
  {
    question: 'Can you pick up from multiple hotels for a group attending a Mariners game?',
    answer: 'Yes. We handle multi-stop pickup routes across Seattle, Bellevue, Kirkland, and beyond. Provide all addresses at booking and we build the route. Our Sprinter van comfortably holds up to 14 passengers from separate hotels before heading to T-Mobile Park.',
  },
  {
    question: 'Do you cover afternoon day games as well as evening games?',
    answer: 'Absolutely. We serve all Mariners home games regardless of start time — afternoon getaway games, weekend day games, and standard evening starts. Just select your game time at booking and we schedule pickup accordingly.',
  },
  {
    question: 'What if the game is rained out or postponed?',
    answer: 'If the Mariners postpone or cancel a game, contact us as soon as the announcement is made and we will reschedule at no penalty. We monitor weather and MLB postponement notices on game days so your chauffeur is already aware of schedule changes.',
  },
  {
    question: 'Can I book a ride for Opening Day weekend?',
    answer: 'Yes — and we strongly recommend booking early. Opening Day weekend is one of the most requested dates of the baseball calendar. Vehicles fill weeks in advance for marquee games. Reserve as soon as the schedule is announced to secure your preferred vehicle and pickup time.',
  },
  {
    question: 'Which areas do you serve for Mariners transportation?',
    answer: 'We cover the full Seattle metro — including Bellevue, Kirkland, Redmond, Renton, Tacoma, Everett, and Issaquah. We also handle runs from further south (Federal Way, Auburn) and north (Lynnwood, Edmonds) for fans making the trip in for a game.',
  },
];

/* ── Structured data ─────────────────────────────────────────────────────── */
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  '@id': `${canonical}#event`,
  name: 'Seattle Mariners Home Season — T-Mobile Park',
  description: 'Seattle Mariners 81-game home schedule at T-Mobile Park, 1250 1st Ave S, Seattle WA 98134. Season runs April through September.',
  startDate: '2025-04-01',
  endDate: '2025-09-30',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'SportsActivityLocation',
    name: 'T-Mobile Park',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '1250 1st Ave S',
      addressLocality: 'Seattle',
      addressRegion: 'WA',
      postalCode: '98134',
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 47.5914,
      longitude: -122.3325,
    },
  },
  organizer: {
    '@type': 'SportsOrganization',
    name: 'Seattle Mariners',
    url: 'https://www.mlb.com/mariners',
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: 'Mariners Game Day Transportation — Seattle',
  description: 'Luxury chauffeur and group transportation for Seattle Mariners home games at T-Mobile Park. Flat-rate pricing, no surge, SUVs and Sprinter vans available.',
  url: canonical,
  serviceType: 'Event Transportation',
  areaServed: {
    '@type': 'City',
    name: 'Seattle',
    sameAs: 'https://en.wikipedia.org/wiki/Seattle',
  },
  provider: {
    '@type': 'LimousineBusiness',
    name: 'Emerald City Limos',
    '@id': SITE_URL,
    url: SITE_URL,
    telephone: '+1-206-595-9675',
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: 'https://customer.moovs.app/a1-charters-1/new/info',
    priceCurrency: 'USD',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',               item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Events',             item: `${SITE_URL}/events` },
    { '@type': 'ListItem', position: 3, name: 'Mariners Game Day',  item: canonical },
  ],
};
---

<MainLayout
  title="Mariners Game Day Transportation Seattle | T-Mobile Park | Emerald City Limos"
  description="Luxury chauffeur service for Seattle Mariners home games at T-Mobile Park. Flat-rate pricing, no surge, no parking fees. SUVs and Sprinter vans — book for any game day."
  keywords="mariners game day transportation seattle, t-mobile park car service, seattle mariners limo, baseball game chauffeur seattle, t-mobile park transportation, seattle mariners ride service"
  canonical={canonical}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <PageHero
    eyebrow="Seattle Mariners · T-Mobile Park"
    headline="First Pitch Ready,"
    headlineAccent="Every Home Game."
    supporting="T-Mobile Park sits in SoDo's most congested block. We get you there before first pitch and home after the final out — flat rate, no surge, no parking fees."
    ctaPrimary={{ label: 'Book Game Day Transport', href: 'https://customer.moovs.app/a1-charters-1/new/info', id: 'cta-mariners-hero-primary' }}
    image={{ src: gameDayImg, alt: 'Game day atmosphere in Seattle — luxury transport to T-Mobile Park' }}
    size="page"
    id="mariners-hero"
    breadcrumbs={[
      { label: 'Home',              href: '/' },
      { label: 'Events',            href: '/events' },
      { label: 'Mariners Game Day' },
    ]}
  />

  <!-- ── Trust strip ───────────────────────────────────────────────────── -->
  <TrustStrip />

  <!-- ── Season info ───────────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-forest-deep py-16 sm:py-20 lg:py-24"
    aria-labelledby="mariners-info-heading"
  >
    <!-- Radial gold glow -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse 60% 70% at 50% 50%, rgba(163,126,44,0.12) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.4), transparent);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.25), transparent);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">

      <!-- Header -->
      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold-soft/60" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
            T-Mobile Park · Seattle, WA
          </p>
          <span class="h-px w-8 bg-brand-gold-soft/60" aria-hidden="true"></span>
        </div>
        <h2
          id="mariners-info-heading"
          class="font-display font-light leading-[1.1] text-white"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          2025 MLB Season at
          <em class="italic text-brand-gold-soft">T-Mobile Park.</em>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl font-sans text-[0.88rem] font-light leading-relaxed text-white/55">
          The Mariners play 81 home games April through September at 1250 1st Ave S, Seattle WA 98134.
          Popular games — Opening Day, rivalry series against the Astros and Angels, and playoff-race finishes — book out early.
          We're ready for every one.
        </p>
      </div>

      <!-- Info cards -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {[
          { label: 'Home Games', value: '81', note: 'April – September' },
          { label: 'Venue', value: 'T-Mobile Park', note: '1250 1st Ave S, SoDo' },
          { label: 'Capacity', value: '47,929', note: 'Seats · plus standing room' },
        ].map(({ label, value, note }) => (
          <div class="flex flex-col items-center gap-2 border border-white/10 bg-white/[0.04] px-6 py-7 text-center">
            <span class="font-sans text-[9px] font-semibold uppercase tracking-[0.2em] text-brand-gold-soft/70">
              {label}
            </span>
            <span
              class="font-display font-light leading-tight text-white"
              style="font-size: clamp(1.5rem, 3vw, 2rem);"
            >
              {value}
            </span>
            <span class="font-sans text-[0.75rem] font-light text-white/40">{note}</span>
          </div>
        ))}
      </div>

      <p class="mt-8 text-center font-sans text-[0.78rem] font-light text-white/40">
        Popular game nights fill our fleet weeks out — book your spot early and update pickup details as game day approaches.
      </p>
    </div>
  </section>

  <!-- ── Why book with us ───────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="mariners-benefits-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/25 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.15fr] lg:gap-16 xl:gap-20">

        <!-- Copy -->
        <div class="flex flex-col">
          <div class="mb-4 flex items-center gap-3">
            <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
              Why Emerald City Limos
            </p>
          </div>
          <h2
            id="mariners-benefits-heading"
            class="mb-6 font-display font-light leading-[1.08] text-brand-forest"
            style="font-size: clamp(1.85rem, 3.4vw, 2.5rem); letter-spacing: -0.01em;"
          >
            Game day without
            <em class="italic text-brand-gold">the grind.</em>
          </h2>
          <p class="font-sans text-[0.98rem] font-light leading-[1.8] text-brand-forest/80 sm:text-[1.02rem]">
            SoDo turns chaotic on game nights — street closures, crowds spilling onto 1st Ave, and
            parking lots that fill hours before first pitch. We've been getting Seattle fans to
            T-Mobile Park for years. The route, the timing, and the post-game pickup are all handled.
          </p>
          <p class="mt-5 border-l-2 border-brand-gold/30 pl-4 font-sans text-[0.92rem] font-light italic leading-[1.75] text-brand-forest/65">
            Season ticket holders attending 10 or more games can ask about our multi-booking packages — one account, one point of contact, all season long.
          </p>
        </div>

        <!-- Benefits grid -->
        <ul
          class="m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2"
          aria-label="Mariners game day transportation benefits"
        >
          {benefits.map((benefit) => (
            <li class="group relative flex flex-col gap-3 border border-brand-forest/8 bg-white p-5 transition-colors duration-300 hover:border-brand-gold/45">
              <span class="inline-flex h-10 w-10 items-center justify-center bg-brand-gold/10 text-brand-gold transition-colors duration-300 group-hover:bg-brand-gold group-hover:text-white">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="18"
                  height="18"
                  aria-hidden="true"
                >
                  <path d={benefit.iconPath} />
                </svg>
              </span>
              <h3 class="font-display text-base font-medium leading-snug text-brand-forest">
                {benefit.title}
              </h3>
              <p class="font-sans text-[0.82rem] leading-relaxed text-brand-forest/70">
                {benefit.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────────────────────────────── -->
  <section
    class="relative bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="mariners-how-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/25 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            How It Works
          </p>
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        </div>
        <h2
          id="mariners-how-heading"
          class="font-display font-light leading-[1.1] text-brand-forest"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Three steps to
          <em class="italic text-brand-gold">game-day ease.</em>
        </h2>
      </div>

      <ol
        class="m-0 grid list-none grid-cols-1 gap-px p-0 border border-brand-forest/8 bg-brand-forest/8 sm:grid-cols-3"
        aria-label="Booking process"
      >
        {[
          {
            step: '01',
            title: 'Reserve Online',
            body: 'Choose your vehicle, enter your pickup address and game date, and lock in your flat rate — takes under two minutes, any time of day.',
          },
          {
            step: '02',
            title: 'We Confirm & Prepare',
            body: 'Booking confirmation lands in your inbox immediately. On game day your chauffeur monitors SoDo closures and traffic to plan the optimal route.',
          },
          {
            step: '03',
            title: 'Door to Stadium and Back',
            body: "We drop you at the park entrance and return you home when the final out is recorded — extra innings included, no extra charge.",
          },
        ].map(({ step, title, body }) => (
          <li class="flex flex-col gap-4 bg-white p-6 sm:p-8">
            <span
              class="font-display text-[3rem] font-light leading-none text-brand-gold/25"
              aria-hidden="true"
            >
              {step}
            </span>
            <h3 class="font-display text-[1.15rem] font-medium leading-snug text-brand-forest">
              {title}
            </h3>
            <p class="font-sans text-[0.85rem] leading-relaxed text-brand-forest/70">
              {body}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Fleet ───────────────────────────────────────────────────────────── -->
  <section
    class="bg-brand-forest py-16 text-brand-champagne sm:py-20 lg:py-24"
    aria-labelledby="mariners-fleet-heading"
  >
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 flex flex-col gap-4 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="mb-3 flex items-center gap-3">
            <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
              Recommended Fleet
            </p>
          </div>
          <h2
            id="mariners-fleet-heading"
            class="font-display font-light leading-[1.1] text-white"
            style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
          >
            The right vehicle for
            <em class="italic text-brand-gold-soft">every group size.</em>
          </h2>
        </div>
        <a
          href="/fleet"
          class="inline-flex w-fit items-center gap-1.5 border-b border-brand-gold-soft/50 pb-1 font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft outline-none transition-colors hover:border-brand-gold-soft hover:text-white focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
        >
          View full fleet
          <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <ul
        role="list"
        class="m-0 grid list-none grid-cols-1 gap-5 p-0 md:grid-cols-2 lg:grid-cols-3"
      >
        {marinersFleet.map((vehicle) => (
          <li class="m-0 p-0">
            <a
              href={vehicle.href}
              class="group relative flex h-full flex-col overflow-hidden border-l-2 border-brand-gold/60 bg-white/[0.04] outline-none ring-1 ring-white/8 transition-[border-color,background-color,box-shadow] duration-300 hover:border-brand-gold-soft hover:bg-white/[0.07] hover:shadow-[0_24px_48px_-32px_rgba(0,0,0,0.6)] focus-visible:border-brand-gold-soft focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
              aria-label={`View ${vehicle.name} on the fleet page`}
            >
              <div class="relative aspect-[4/3] w-full overflow-hidden bg-brand-forest-deep">
                {vehicle.imageSrc ? (
                  <img
                    src={typeof vehicle.imageSrc === 'string' ? vehicle.imageSrc : vehicle.imageSrc!.src}
                    alt={vehicle.imageAlt}
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="600"
                    class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                    <span
                      class="absolute inset-0"
                      style="background: radial-gradient(ellipse 60% 55% at center, var(--color-brand-gold-soft) 0%, transparent 70%); opacity: 0.16;"
                    ></span>
                    <span class="font-display text-2xl italic text-brand-gold-soft/70">
                      {vehicle.category}
                    </span>
                  </div>
                )}
                <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 bg-brand-forest/85 px-2 py-1 font-sans text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-brand-gold-soft backdrop-blur-sm">
                  {vehicle.category}
                </span>
              </div>

              <div class="flex flex-1 flex-col gap-3 p-5">
                <h3 class="font-display text-lg font-medium leading-tight text-white">
                  {vehicle.name}
                </h3>
                <p class="font-sans text-[0.78rem] font-medium tabular-nums text-brand-gold-soft">
                  {vehicle.capacityLabel}
                </p>
                <ul role="list" class="m-0 list-none space-y-1 p-0">
                  {vehicle.features.slice(0, 3).map((feature) => (
                    <li class="flex items-start gap-2 font-sans text-[0.78rem] leading-snug text-white/70">
                      <span class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-brand-gold-soft" aria-hidden="true"></span>
                      {feature}
                    </li>
                  ))}
                </ul>
                <span class="mt-auto inline-flex items-center gap-1.5 font-sans text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft transition-colors group-hover:text-white">
                  View vehicle
                  <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────── -->
  <section
    class="bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="mariners-faq-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/15 to-transparent"
      aria-hidden="true"
    ></div>
    <div class="mx-auto max-w-4xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            Common Questions
          </p>
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        </div>
        <h2
          id="mariners-faq-heading"
          class="font-display font-light leading-[1.1] text-brand-forest"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Game day transport,
          <em class="italic text-brand-gold">answered.</em>
        </h2>
      </div>

      <ul role="list" class="m-0 list-none space-y-3 p-0">
        {faqs.map((faq, index) => (
          <li class="m-0 p-0">
            <details
              class="group relative border border-brand-forest/8 bg-white transition-[border-color,box-shadow] duration-300 open:border-brand-gold/40 open:shadow-[0_18px_36px_-28px_rgba(10,35,24,0.25)] hover:border-brand-gold/30"
              name="mariners-faq"
            >
              <summary class="flex cursor-pointer items-start gap-4 px-5 py-4 outline-none transition-colors focus-visible:bg-brand-gold/[0.04] sm:px-6 sm:py-5 [&::-webkit-details-marker]:hidden [&::marker]:hidden">
                <span
                  class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center font-sans text-[0.7rem] font-semibold tabular-nums text-brand-gold"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="flex-1 font-display text-[1.05rem] font-medium leading-snug text-brand-forest sm:text-[1.12rem]">
                  {faq.question}
                </span>
                <span
                  class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center text-brand-gold transition-transform duration-300 group-open:rotate-45"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                    <path d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                </span>
              </summary>
              <div class="px-5 pb-5 pl-[3.5rem] sm:px-6 sm:pb-6 sm:pl-[3.75rem]">
                <p class="font-sans text-[0.92rem] font-light leading-[1.75] text-brand-forest/75">
                  {faq.answer}
                </p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Closing CTA ────────────────────────────────────────────────────── -->
