---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
import { getVehicle } from '@/data/fleet';
import lumenFieldImg from '@/assets/images/world-cup/lumen-field.jpg';

import type { Vehicle } from '@/data/fleet';

const seahawksFleet = ['escalade-esv', 'sprinter', 'navigator-l']
  .map(getVehicle)
  .filter((v): v is Vehicle => v != null);

const SITE_URL = 'https://emeraldcitylimos.com';
const canonical = `${SITE_URL}/events/seahawks-game-day`;

/* ── Season info ─────────────────────────────────────────────────────────── */
const seasonInfo = [
  { slot: '01', label: 'Home Game',   note: 'Schedule released in May — book early' },
  { slot: '02', label: 'Home Game',   note: 'Schedule released in May — book early' },
  { slot: '03', label: 'Home Game',   note: 'Schedule released in May — book early' },
  { slot: '04', label: 'Home Game',   note: 'Prime-time matchup — fills fast' },
  { slot: '05', label: 'Home Game',   note: 'Schedule released in May — book early' },
  { slot: '06', label: 'Divisional',  note: 'High demand — reserve early' },
  { slot: '07', label: 'Home Game',   note: 'Schedule released in May — book early' },
  { slot: '08', label: 'Divisional',  note: 'High demand — reserve early' },
  { slot: '09', label: 'Home Game',   note: 'Schedule released in May — book early' },
];

/* ── Benefits ────────────────────────────────────────────────────────────── */
const benefits = [
  {
    title: 'Stadium Drop-Off Lane',
    description: "Lumen Field's designated black-car lane puts you steps from the gates — no walk from a remote lot, no shuttle wait.",
    iconPath: 'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  },
  {
    title: 'Flat-Rate Pricing',
    description: 'Your fare is locked at booking. No surge after the final whistle — whether the game goes to OT or ends in regulation.',
    iconPath: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Groups Welcome',
    description: 'From an SUV for four friends to a Sprinter for a suite crowd — one booking handles your whole party, no coordinating multiple rideshares.',
    iconPath: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
  },
  {
    title: 'Post-Game Curbside Return',
    description: 'Your chauffeur is staged and ready when the crowd exits. No competing with 68,000 fans opening the same rideshare app at once.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Tailgate-Ready Pickup',
    description: 'Cooler space, no luggage fees, and multi-stop pickups across Seattle, Bellevue, or the Eastside — start the party before you arrive.',
    iconPath: 'M6 12L3.269 3.125A59.769 59.769 0 0121.485 12 59.768 59.768 0 013.27 20.875L5.999 12zm0 0h7.5',
  },
  {
    title: 'Closure-Aware Routing',
    description: 'Our chauffeurs know SoDo game-day closures and post-game traffic patterns — we route around the bottlenecks before they form.',
    iconPath: 'M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z',
  },
];

/* ── FAQs ─────────────────────────────────────────────────────────────────── */
const faqs = [
  {
    question: 'How far is Lumen Field from downtown Seattle hotels?',
    answer: "Lumen Field is roughly 1–2 miles from most downtown Seattle hotels — about a 5-minute drive under normal conditions. On game day, however, road closures, pedestrian crossings, and parking gridlock in SoDo can make that same trip unpredictable. A private black-car drop-off directly to the stadium lane removes the guesswork entirely.",
  },
  {
    question: 'Can you handle a group of 10 or more for a Seahawks game?',
    answer: 'Yes. Our Mercedes Sprinter vans accommodate up to 14 passengers comfortably, and we can deploy multiple vehicles for larger groups. For corporate suites or large party bookings, we coordinate multi-stop pickup routes across Seattle, Bellevue, Kirkland, Redmond, and Tacoma so everyone arrives together.',
  },
  {
    question: 'Do you offer tailgate packages?',
    answer: 'We do. Our game-day packages include pre-game multi-stop pickups, cooler-friendly cargo space, and a dedicated return window after the final whistle. If you want to hit a specific bar or parking lot tailgate before kickoff, we build that into the itinerary at no extra charge.',
  },
  {
    question: 'What happens if the game goes to overtime?',
    answer: 'Nothing changes on your end. Your fare is flat-rate and locked at booking — overtime, a long post-game ceremony, or traffic delays do not add to your bill. Your chauffeur monitors game status in real time and adjusts the staging time accordingly so they are curbside when you are ready to leave.',
  },
  {
    question: 'Which areas do you serve for Seahawks game transport?',
    answer: 'We serve all of King, Pierce, and Snohomish counties — including Seattle, Bellevue, Kirkland, Redmond, Bothell, Tacoma, and Everett. We also handle runs from the Sea-Tac Airport corridor for fans flying in for a game.',
  },
  {
    question: 'Can I book a round trip — hotel to stadium and back?',
    answer: 'Absolutely. Round-trip bookings are our most popular game-day option. Reserve your pickup time to the stadium and a return window after the game in one booking. Your chauffeur handles both legs — you pay one flat rate with no surprises.',
  },
];

/* ── Structured data ─────────────────────────────────────────────────────── */
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  '@id': `${canonical}#event`,
  name: 'Seattle Seahawks Home Games at Lumen Field',
  description: 'Seattle Seahawks regular season home games at Lumen Field, Seattle, Washington. 9 home games per season.',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'SportsActivityLocation',
    name: 'Lumen Field',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '800 Occidental Ave S',
      addressLocality: 'Seattle',
      addressRegion: 'WA',
      postalCode: '98134',
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 47.5952,
      longitude: -122.3316,
    },
  },
  organizer: {
    '@type': 'SportsOrganization',
    name: 'Seattle Seahawks',
    url: 'https://www.seahawks.com',
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: 'Seattle Seahawks Game Day Transportation',
  description: 'Luxury chauffeur and group transportation services for Seattle Seahawks home games at Lumen Field. Flat-rate pricing, SUVs, Sprinter vans, post-game curbside return.',
  url: canonical,
  serviceType: 'Event Transportation',
  areaServed: {
    '@type': 'City',
    name: 'Seattle',
    sameAs: 'https://en.wikipedia.org/wiki/Seattle',
  },
  provider: {
    '@type': 'LimousineBusiness',
    name: 'Emerald City Limos',
    '@id': SITE_URL,
    url: SITE_URL,
    telephone: '+1-206-595-9675',
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: 'https://customer.moovs.app/a1-charters-1/new/info',
    priceCurrency: 'USD',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Events', item: `${SITE_URL}/events` },
    { '@type': 'ListItem', position: 3, name: 'Seahawks Game Day Transportation Seattle', item: canonical },
  ],
};
---

<MainLayout
  title="Seattle Seahawks Game Day Transportation | Lumen Field | Emerald City Limos"
  description="Luxury chauffeur service for Seattle Seahawks home games at Lumen Field. Flat-rate pricing, no surge, curbside post-game return. SUVs to Sprinter vans. Book your game day ride."
  keywords="seahawks game day transportation, seahawks limo seattle, lumen field car service, seattle seahawks shuttle, game day chauffeur seattle, seahawks transportation service"
  canonical={canonical}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <PageHero
    eyebrow="Seattle Seahawks · Lumen Field"
    headline="Game Day in Seattle,"
    headlineAccent="Done Right."
    supporting="Lumen Field on game day is a traffic nightmare. Skip the parking hunt and rideshare surge — we get you to your seat on time and home without the chaos."
    ctaPrimary={{ label: 'Book Game Day Ride', href: 'https://customer.moovs.app/a1-charters-1/new/info', id: 'cta-seahawks-hero-primary' }}
    image={{ src: lumenFieldImg, alt: 'Lumen Field in Seattle — home of the Seattle Seahawks' }}
    size="page"
    id="seahawks-hero"
    breadcrumbs={[
      { label: 'Home',   href: '/' },
      { label: 'Events', href: '/events' },
      { label: 'Seahawks Game Day' },
    ]}
  />

  <!-- ── Trust strip ───────────────────────────────────────────────────── -->
  <TrustStrip />

  <!-- ── Season info block ─────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-forest py-16 sm:py-20 lg:py-24"
    aria-labelledby="seahawks-schedule-heading"
  >
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse 80% 50% at 100% 50%, rgba(163,126,44,0.08) 0%, transparent 60%);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.3), transparent);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-px"
      style="background: linear-gradient(to right, transparent, rgba(195,154,69,0.2), transparent);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">

      <!-- Header -->
      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold-soft/60" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
            Lumen Field · Seattle, WA
          </p>
          <span class="h-px w-8 bg-brand-gold-soft/60" aria-hidden="true"></span>
        </div>
        <h2
          id="seahawks-schedule-heading"
          class="font-display font-light leading-[1.1] text-white"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          2025 Season at Lumen Field —
          <em class="italic text-brand-gold-soft">9 home games.</em>
        </h2>
        <p class="mx-auto mt-4 max-w-lg font-sans text-[0.88rem] font-light leading-relaxed text-white/55">
          The NFL releases the full schedule in May each year. Book early for divisional games
          and prime-time matchups — those slots fill fastest.
        </p>
      </div>

      <!-- Game cards -->
      <ol
        class="m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2"
        role="list"
        aria-label="2025 Seahawks home game slots"
      >
        {seasonInfo.map((game) => (
          <li class:list={[
            'group relative flex items-center gap-5 border bg-white/[0.04] px-5 py-4 transition-colors duration-300 hover:bg-white/[0.07] sm:px-6 sm:py-5',
            game.label === 'Divisional'
              ? 'border-brand-gold/35'
              : 'border-white/10',
          ]}>
            <!-- Game number -->
            <span
              class:list={[
                'inline-flex h-10 w-10 shrink-0 items-center justify-center border font-sans text-[0.72rem] font-semibold tabular-nums',
                game.label === 'Divisional'
                  ? 'border-brand-gold/50 text-brand-gold-soft'
                  : 'border-white/15 text-white/50',
              ]}
              aria-hidden="true"
            >
              {game.slot}
            </span>

            <!-- Details -->
            <div class="flex flex-1 flex-col gap-0.5">
              <span
                class:list={[
                  'font-sans text-[9px] font-semibold uppercase tracking-[0.18em]',
                  game.label === 'Divisional' ? 'text-brand-gold-soft' : 'text-white/40',
                ]}
              >
                {game.label}
              </span>
              <span class="font-display text-[1.05rem] font-medium leading-snug text-white">
                Opponent TBD
              </span>
              <span class="font-sans text-[0.78rem] font-light text-white/40">
                {game.note}
              </span>
            </div>

            <!-- Status label -->
            <span
              class:list={[
                'hidden shrink-0 self-center font-sans text-[9px] font-semibold uppercase tracking-[0.14em] sm:block',
                game.label === 'Divisional' ? 'text-brand-gold-soft/70' : 'text-white/25',
              ]}
            >
              Date TBD
            </span>
          </li>
        ))}
      </ol>

      <!-- Schedule note -->
      <p class="mt-6 text-center font-sans text-[0.75rem] font-light text-white/35">
        NFL schedule released in May. Confirm at
        <a
          href="https://www.seahawks.com/schedule"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-gold-soft/70 underline underline-offset-2 hover:text-brand-gold-soft"
        >
          seahawks.com
        </a>
      </p>
    </div>
  </section>

  <!-- ── Why book with us ───────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="seahawks-benefits-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/25 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.15fr] lg:gap-16 xl:gap-20">

        <!-- Copy -->
        <div class="flex flex-col">
          <div class="mb-4 flex items-center gap-3">
            <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
              Why Emerald City Limos
            </p>
          </div>
          <h2
            id="seahawks-benefits-heading"
            class="mb-6 font-display font-light leading-[1.08] text-brand-forest"
            style="font-size: clamp(1.85rem, 3.4vw, 2.5rem); letter-spacing: -0.01em;"
          >
            Game day without
            <em class="italic text-brand-gold">the chaos.</em>
          </h2>
          <p class="font-sans text-[0.98rem] font-light leading-[1.8] text-brand-forest/80 sm:text-[1.02rem]">
            Lumen Field sits in SoDo — Seattle's most congested corridor on NFL Sundays.
            Parking lots fill two hours before kickoff, rideshares surge 3–5× post-game,
            and the walk from street parking to the gate is longer than it looks on a map.
            We've been running game-day transport in Seattle for over a decade. We know
            every closure, every bottleneck, and every trick to get you there on time.
          </p>
          <p class="mt-5 border-l-2 border-brand-gold/30 pl-4 font-sans text-[0.92rem] font-light italic leading-[1.75] text-brand-forest/65">
            Book early for prime-time and divisional games — those dates fill weeks in advance
            once the NFL schedule drops each May.
          </p>
        </div>

        <!-- Benefits grid -->
        <ul
          class="m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2"
          aria-label="Seahawks game day transportation benefits"
        >
          {benefits.map((benefit) => (
            <li class="group relative flex flex-col gap-3 border border-brand-forest/8 bg-white p-5 transition-colors duration-300 hover:border-brand-gold/45">
              <span class="inline-flex h-10 w-10 items-center justify-center bg-brand-gold/10 text-brand-gold transition-colors duration-300 group-hover:bg-brand-gold group-hover:text-white">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="18"
                  height="18"
                  aria-hidden="true"
                >
                  <path d={benefit.iconPath} />
                </svg>
              </span>
              <h3 class="font-display text-base font-medium leading-snug text-brand-forest">
                {benefit.title}
              </h3>
              <p class="font-sans text-[0.82rem] leading-relaxed text-brand-forest/70">
                {benefit.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────────────────────────────── -->
  <section
    class="relative bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="seahawks-how-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/25 to-transparent"
      aria-hidden="true"
    ></div>

    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            How It Works
          </p>
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        </div>
        <h2
          id="seahawks-how-heading"
          class="font-display font-light leading-[1.1] text-brand-forest"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Three steps to
          <em class="italic text-brand-gold">game-day ease.</em>
        </h2>
      </div>

      <ol
        class="m-0 grid list-none grid-cols-1 gap-px p-0 border border-brand-forest/8 bg-brand-forest/8 sm:grid-cols-3"
        aria-label="Booking process"
      >
        {[
          {
            step: '01',
            title: 'Reserve Online',
            body: 'Choose your vehicle, enter your pickup location and game date, and lock in your flat rate — takes under two minutes from any device.',
          },
          {
            step: '02',
            title: 'We Confirm & Monitor',
            body: 'You receive a booking confirmation immediately. On game day, your chauffeur monitors kickoff time and SoDo road closures to time the pickup perfectly.',
          },
          {
            step: '03',
            title: 'Door to Stadium & Back',
            body: "We pick you up where you are, drop you at the stadium lane, and return you curbside when the game ends — on time, every time, no surge pricing.",
          },
        ].map(({ step, title, body }) => (
          <li class="flex flex-col gap-4 bg-white p-6 sm:p-8">
            <span
              class="font-display text-[3rem] font-light leading-none text-brand-gold/25"
              aria-hidden="true"
            >
              {step}
            </span>
            <h3 class="font-display text-[1.15rem] font-medium leading-snug text-brand-forest">
              {title}
            </h3>
            <p class="font-sans text-[0.85rem] leading-relaxed text-brand-forest/70">
              {body}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Fleet ───────────────────────────────────────────────────────────── -->
  <section
    class="bg-brand-forest py-16 text-brand-champagne sm:py-20 lg:py-24"
    aria-labelledby="seahawks-fleet-heading"
  >
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 flex flex-col gap-4 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="mb-3 flex items-center gap-3">
            <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
            <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
              Recommended Fleet
            </p>
          </div>
          <h2
            id="seahawks-fleet-heading"
            class="font-display font-light leading-[1.1] text-white"
            style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
          >
            The right vehicle for
            <em class="italic text-brand-gold-soft">every group size.</em>
          </h2>
        </div>
        <a
          href="/fleet"
          class="inline-flex w-fit items-center gap-1.5 border-b border-brand-gold-soft/50 pb-1 font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft outline-none transition-colors hover:border-brand-gold-soft hover:text-white focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
        >
          View full fleet
          <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <ul
        role="list"
        class="m-0 grid list-none grid-cols-1 gap-5 p-0 md:grid-cols-2 lg:grid-cols-3"
      >
        {seahawksFleet.map((vehicle) => (
          <li class="m-0 p-0">
            <a
              href={vehicle.href}
              class="group relative flex h-full flex-col overflow-hidden border-l-2 border-brand-gold/60 bg-white/[0.04] outline-none ring-1 ring-white/8 transition-[border-color,background-color,box-shadow] duration-300 hover:border-brand-gold-soft hover:bg-white/[0.07] hover:shadow-[0_24px_48px_-32px_rgba(0,0,0,0.6)] focus-visible:border-brand-gold-soft focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
              aria-label={`View ${vehicle.name} on the fleet page`}
            >
              <div class="relative aspect-[4/3] w-full overflow-hidden bg-brand-forest-deep">
                {vehicle.imageSrc ? (
                  <img
                    src={typeof vehicle.imageSrc === 'string' ? vehicle.imageSrc : vehicle.imageSrc!.src}
                    alt={vehicle.imageAlt}
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="600"
                    class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                    <span
                      class="absolute inset-0"
                      style="background: radial-gradient(ellipse 60% 55% at center, var(--color-brand-gold-soft) 0%, transparent 70%); opacity: 0.16;"
                    ></span>
                    <span class="font-display text-2xl italic text-brand-gold-soft/70">
                      {vehicle.category}
                    </span>
                  </div>
                )}
                <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 bg-brand-forest/85 px-2 py-1 font-sans text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-brand-gold-soft backdrop-blur-sm">
                  {vehicle.category}
                </span>
              </div>

              <div class="flex flex-1 flex-col gap-3 p-5">
                <h3 class="font-display text-lg font-medium leading-tight text-white">
                  {vehicle.name}
                </h3>
                <p class="font-sans text-[0.78rem] font-medium tabular-nums text-brand-gold-soft">
                  {vehicle.capacityLabel}
                </p>
                <ul role="list" class="m-0 list-none space-y-1 p-0">
                  {vehicle.features.slice(0, 3).map((feature) => (
                    <li class="flex items-start gap-2 font-sans text-[0.78rem] leading-snug text-white/70">
                      <span class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-brand-gold-soft" aria-hidden="true"></span>
                      {feature}
                    </li>
                  ))}
                </ul>
                <span class="mt-auto inline-flex items-center gap-1.5 font-sans text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-brand-gold-soft transition-colors group-hover:text-white">
                  View vehicle
                  <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────── -->
  <section
    class="bg-brand-champagne py-16 sm:py-20 lg:py-24"
    aria-labelledby="seahawks-faq-heading"
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-gold/15 to-transparent"
      aria-hidden="true"
    ></div>
    <div class="mx-auto max-w-4xl px-6 sm:px-8 lg:px-12">

      <div class="mb-10 text-center sm:mb-14">
        <div class="mb-3 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold">
            Common Questions
          </p>
          <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        </div>
        <h2
          id="seahawks-faq-heading"
          class="font-display font-light leading-[1.1] text-brand-forest"
          style="font-size: clamp(1.75rem, 3.4vw, 2.4rem); letter-spacing: -0.01em;"
        >
          Game day transport,
          <em class="italic text-brand-gold">answered.</em>
        </h2>
      </div>

      <ul role="list" class="m-0 list-none space-y-3 p-0">
        {faqs.map((faq, index) => (
          <li class="m-0 p-0">
            <details
              class="group relative border border-brand-forest/8 bg-white transition-[border-color,box-shadow] duration-300 open:border-brand-gold/40 open:shadow-[0_18px_36px_-28px_rgba(10,35,24,0.25)] hover:border-brand-gold/30"
              name="seahawks-faq"
            >
              <summary class="flex cursor-pointer items-start gap-4 px-5 py-4 outline-none transition-colors focus-visible:bg-brand-gold/[0.04] sm:px-6 sm:py-5 [&::-webkit-details-marker]:hidden [&::marker]:hidden">
                <span
                  class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center font-sans text-[0.7rem] font-semibold tabular-nums text-brand-gold"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="flex-1 font-display text-[1.05rem] font-medium leading-snug text-brand-forest sm:text-[1.12rem]">
                  {faq.question}
                </span>
                <span
                  class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center text-brand-gold transition-transform duration-300 group-open:rotate-45"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                    <path d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                </span>
              </summary>
              <div class="px-5 pb-5 pl-[3.5rem] sm:px-6 sm:pb-6 sm:pl-[3.75rem]">
                <p class="font-sans text-[0.92rem] font-light leading-[1.75] text-brand-forest/75">
                  {faq.answer}
                </p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Closing CTA ────────────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-forest-deep py-16 text-brand-champagne sm:py-20 lg:py-24"
    aria-labelledby="seahawks-cta-heading"
  >
