---
import { Image } from 'astro:assets';
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
import FleetSection from '@/components/fleet/FleetSection.astro';
import heroImage from "@/assets/images/hero/emerald-city-hero.png";
import mobileHero from "@/assets/images/hero/emerald-city-hero.webp";
import aboutImage from "@/assets/images/about/about.png"

const PHONE_DISPLAY = '(206) 595-9675';
const PHONE_TEL     = 'tel:+12065959675';

// Service tiles — replaces the emoji grid with named SVG icons.
// Order matches the strongest commercial intent first (airport, executive, weddings).
const services = [
  {
    href:  '/airport-transfers',
    title: 'Airport Transfers',
    blurb: 'Flat-rate SeaTac and Boeing Field service. Flight tracking and meet-and-greet 24/7.',
    icon:  'plane',
  },
  {
    href:  '/service/executive-transportation',
    title: 'Executive Transport',
    blurb: 'Discreet black-car service for Seattle business travel and corporate events.',
    icon:  'briefcase',
  },
  {
    href:  '/service/wedding-transportation',
    title: 'Weddings',
    blurb: 'Red-carpet arrivals, bridal-party logistics, and venue coordination.',
    icon:  'rings',
  },
  {
    href:  '/service/hourly-charters',
    title: 'Hourly Charters',
    blurb: 'Flexible by-the-hour service for tours, meetings, and a night on the town.',
    icon:  'clock',
  },
  {
    href:  '/service/cruise-transportation',
    title: 'Cruise Transfers',
    blurb: 'Smith Cove and Bell Street pier transfers, luggage handled.',
    icon:  'ship',
  },
  {
    href:  '/service/game-day-transport',
    title: 'Game Day',
    blurb: 'Seahawks, Mariners, Sounders and Kraken — arrive without the parking.',
    icon:  'trophy',
  },
  {
    href:  '/service/special-occasions',
    title: 'Special Occasions',
    blurb: 'Birthdays, anniversaries, prom — every milestone in measured luxury.',
    icon:  'sparkles',
  },
  {
    href:  '/service/infant-car-seats',
    title: 'Infant & Booster Seats',
    blurb: 'Pre-installed, properly fitted car seats for safe family travel.',
    icon:  'baby',
  },
];

// Stroke icon paths (Heroicons outline + custom). Single inline registry — no extra files.
const ICONS: Record<string, string> = {
  plane:     'M6 12L3.269 3.125A59.769 59.769 0 0121.485 12 59.768 59.768 0 013.27 20.875L5.999 12zm0 0h7.5',
  briefcase: 'M20.25 14.15v4.07a2.25 2.25 0 01-2.25 2.25h-12a2.25 2.25 0 01-2.25-2.25v-4.07m16.5 0a24.094 24.094 0 01-8.25 1.45 24.094 24.094 0 01-8.25-1.45m16.5 0v-2.62a2.25 2.25 0 00-1.632-2.163l-3.05-.872a2.25 2.25 0 01-1.632-2.163V5.625A2.625 2.625 0 0014.625 3h-5.25A2.625 2.625 0 006.75 5.625v.755a2.25 2.25 0 01-1.632 2.163l-3.05.872A2.25 2.25 0 00.436 11.578v2.572m19.814 0H3.75',
  rings:     'M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-7.5l3.5 3-3.5 3-3.5-3 3.5-3z',
  clock:     'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  ship:      'M21 12.75a9 9 0 11-18 0 9 9 0 0118 0zm-3 0H6m12 4.5H6m12-9H6',
  trophy:    'M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0',
  sparkles:  'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z',
  baby:      'M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.318M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z',
};

// Service-area chips: keep one-keyword-per-chip for SEO, restyle for luxury feel.
const areas = [
  { name: 'Seattle',        href: '/locations/seattle'        },
  { name: 'Bellevue',       href: '/locations/bellevue'       },
  { name: 'Redmond',        href: '/locations/redmond'        },
  { name: 'Kirkland',       href: '/locations/kirkland'       },
  { name: 'Renton',         href: '/locations/renton'         },
  { name: 'Tacoma',         href: '/locations/tacoma'         },
  { name: 'Everett',        href: '/locations/everett'        },
  { name: 'Lynnwood',       href: '/locations/lynnwood'       },
  { name: 'Edmonds',        href: '/locations/edmonds'        },
  { name: 'Bothell',        href: '/locations/bothell'        },
  { name: 'Woodinville',    href: '/locations/woodinville'    },
  { name: 'Auburn',         href: '/locations/auburn'         },
  { name: 'Federal Way',    href: '/locations/federal-way'    },
  { name: 'Sammamish',      href: '/locations/sammamish'      },
  { name: 'Kent',           href: '/locations/kent'           },
  { name: 'Lakewood',       href: '/locations/lakewood'       },
  { name: 'Puyallup',       href: '/locations/puyallup'       },
  { name: 'Marysville',     href: '/locations/marysville'     },
  { name: 'SeaTac Airport', href: '/airport/sea-tac'          },
  { name: 'Boeing Field',   href: '/airport/boeing-field'     },
];

// LocalBusiness / LimousineService schema lives in BaseLayout — already wired
// with aggregateRating, areaServed, openingHours, sameAs links, and ReserveAction.
// Adding a second JSON-LD block here would create competing entities for the same business.
---

<MainLayout
  title="Seattle Limo Service | Airport Transfers & Black Car | Emerald City Limos"
  description="Seattle's premium luxury chauffeur service since 2010. Flat-rate SeaTac airport transfers, executive black-car service, weddings and special events. Licensed, insured, available 24/7."
  keywords="seattle limo service, seatac airport limo, luxury car service seattle, black car service seattle, seattle airport transportation, corporate limo seattle, wedding limo seattle"
>
  <!-- ════════════════════════════════════════════════════════════════════
       HERO
       ════════════════════════════════════════════════════════════════════ -->
  <PageHero
    eyebrow="Seattle Luxury Chauffeur & Airport Transportation"
    headline="Refined Private Transportation"
    headlineAccent="Across Greater Seattle"
    supporting="Executive airport transfers, corporate travel, cruise transportation, and private chauffeur service tailored for Seattle’s business travelers, visitors, and special occasions."
    ctaPrimary={{ label: 'Reserve Your Ride', href: 'https://customer.moovs.app/a1-charters-1/new/info', id: 'cta-hero-book' }}
    ctaSecondary={{ label: PHONE_DISPLAY, href: PHONE_TEL, id: 'cta-hero-call', phone: PHONE_DISPLAY }}
    image={{
      src: heroImage,
      srcMobile: mobileHero,
      alt: 'Professional chauffeur beside a luxury black SUV with Seattle skyline and Mount Rainier in the background',
      width: 1672,
      height: 941,
    }}
    size="full"
    id="hero-headline"
  />
  <TrustStrip />

    <!-- ════════════════════════════════════════════════════════════════════
       SERVICES — modernized: spaced cards, animated gold hairline, icon chip
       Tokens only: brand-* colors, font-display/font-sans, Tailwind scale.
       ════════════════════════════════════════════════════════════════════ -->
  <section class="relative bg-white py-20 sm:py-24 lg:py-32" aria-labelledby="services-heading">
    <div class="mx-auto max-w-7xl px-6 sm:px-8">

      <header class="mx-auto mb-14 max-w-2xl text-center sm:mb-16 lg:mb-20">
        <p class="font-sans text-xs font-semibold uppercase tracking-widest text-brand-gold">
          Our Services
        </p>
        <h2
          id="services-heading"
          class="mt-4 font-display text-3xl font-light leading-tight tracking-tight text-brand-forest sm:text-4xl lg:text-5xl"
        >
          Every journey,
          <em class="italic text-brand-gold">perfected</em>.
        </h2>
        <p class="mt-5 font-sans text-base font-light leading-relaxed text-neutral-700 sm:text-lg">
          From SeaTac at dawn to a Pike Place wedding at dusk &mdash; white-glove transport for every occasion.
        </p>
      </header>

      <ul role="list" class="grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-4">
        {services.map((s) => (
          <li>
            <a
              href={s.href}
              class="ecl-focusable group relative flex h-full flex-col bg-white p-7 ring-1 ring-brand-forest/10 transition duration-300 hover:ring-brand-gold sm:p-8"
            >
              <span
                class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-brand-gold transition-transform duration-500 ease-out group-hover:scale-x-100 group-focus-visible:scale-x-100"
                aria-hidden="true"
              ></span>

              <span class="mb-6 inline-flex h-12 w-12 items-center justify-center bg-brand-champagne text-brand-gold transition-colors duration-300 group-hover:bg-brand-gold group-hover:text-white">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.25"
                  width="24"
                  height="24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={ICONS[s.icon]} />
                </svg>
              </span>

              <h3 class="font-display text-2xl font-medium leading-snug text-brand-forest transition-colors duration-300 group-hover:text-brand-gold">
                {s.title}
              </h3>
              <p class="mt-3 font-sans text-sm leading-relaxed text-neutral-600">
                {s.blurb}
              </p>

              <span class="mt-auto inline-flex items-center gap-2 pt-6 font-sans text-xs font-semibold uppercase tracking-widest text-brand-forest transition-colors duration-300 group-hover:text-brand-gold">
                Learn more
                <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-14 text-center sm:mt-16">
        <a
          href="/services"
          class="ecl-focusable inline-flex items-center gap-2 border-b border-brand-gold pb-1 font-sans text-xs font-semibold uppercase tracking-widest text-brand-forest transition-colors hover:text-brand-gold"
        >
          View all services
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

    <FleetSection
      showFilters={false}
      limit={4}
    />

  <!-- ════════════════════════════════════════════════════════════════════
     ABOUT — editorial asymmetric luxury layout
     ════════════════════════════════════════════════════════════════════ -->
  <section class="relative bg-brand-forest overflow-hidden py-20 sm:py-28 px-6 sm:px-8" aria-labelledby="about-heading">

    <!-- Full-bleed background image -->
    <Image
      src={aboutImage}
      alt=""
      width={1200}
      height={900}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover object-center"
      aria-hidden="true"
    />
    <!-- Dark overlay for readability -->
    <div class="absolute inset-0 bg-brand-forest/70" aria-hidden="true"></div>

    <!-- Vertical rule — decorative left spine, desktop only -->
    <div class="absolute left-0 top-0 hidden lg:block h-full w-px bg-white/[.07]" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto relative z-10">

      <!-- ── Top row: eyebrow + running headline ── -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-14 sm:mb-16 lg:mb-20">
        <div class="flex items-center gap-4">
          <div class="hidden sm:block h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
          <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
            Established Seattle &rsquo;10
          </p>
        </div>
        <p class="font-sans text-[11px] font-medium tracking-[0.16em] uppercase text-white/40 sm:text-right">
          King &middot; Snohomish &middot; Pierce
        </p>
      </div>

      <!-- ── Main editorial grid ── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Left column: stacked content -->
        <div class="flex flex-col">

          <!-- Dominant heading -->
          <h2
            id="about-heading"
            class="font-display font-light text-white leading-[1.04] tracking-[-0.025em] mb-10 lg:mb-0"
            style="font-size: clamp(2.75rem, 6vw, 5rem);"
          >
            A quieter<br>
            standard of<br>
            <em class="text-brand-gold italic">arrival</em>.
          </h2>

          <!-- Stat cards — desktop only -->
          <div class="hidden lg:flex flex-col gap-3 mt-10" aria-label="Company statistics">
            {[
              { value: '15+', label: 'Years serving Seattle' },
              { value: '24/7', label: 'Available year-round'  },
            ].map((stat) => (
              <div
                class="group flex items-center gap-5 bg-white px-6 py-4 ring-1 ring-brand-forest/10 transition-all duration-300text-ring-brand-gold w-[260px]"
                role="listitem"
                aria-label={`${stat.value} — ${stat.label}`}
              >
                <span
                  class="font-display font-light text-brand-forest leading-none transition-colors duration-300 group-hover:text-brand-gold"
                  style="font-size: clamp(1.5rem, 2.5vw, 2rem);"
                >
                  {stat.value}
                </span>
                <div class="h-8 w-px bg-brand-forest/10 shrink-0" aria-hidden="true"></div>
                <span class="font-sans text-[10px] font-medium tracking-[0.14em] uppercase text-brand-forest/50">
                  {stat.label}
                </span>
              </div>
            ))}
          </div>

        </div>

        <!-- Right column: copy card -->
        <div class="relative mt-10 lg:mt-0">
          <div class="relative bg-white ring-1 ring-brand-forest/10 px-7 py-8 sm:px-8 sm:py-9">
            <!-- Animated gold hairline -->
            <div
              class="absolute inset-x-0 top-0 h-px origin-left bg-brand-gold scale-x-0 transition-transform duration-700 ease-out"
              style="animation: scaleIn 1.2s cubic-bezier(0.25,0.46,0.45,0.94) 0.3s forwards;"
              aria-hidden="true"
            ></div>

            <p class="font-sans text-sm sm:text-base leading-[1.78] text-neutral-700 mb-5">
              For over a decade, Emerald City Limos has served the Greater Seattle area with chauffeurs who anticipate, vehicles that perform, and a standard of service that doesn&rsquo;t announce itself.
            </p>
            <p class="font-sans text-sm sm:text-base leading-[1.78] text-neutral-700 mb-7">
              Whether the destination is SeaTac at 4&nbsp;a.m., a Pike Place wedding, a Seahawks Sunday, or a downtown board meeting &mdash; we deliver the same answer. Quietly, every time.
            </p>

            <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
              <a href="/about"
                class="ecl-focusable inline-flex items-center gap-2 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase text-brand-forest border-b border-brand-gold pb-1 transition-colors hover:text-brand-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
                aria-label="Learn more about Emerald City Limos"
              >
                Our story
                <span aria-hidden="true">→</span>
              </a>
              <a href="/locations"
                class="ecl-focusable inline-flex items-center gap-2 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase text-brand-forest/50 border-b border-brand-forest/20 pb-1 transition-colors hover:text-brand-forest hover:border-brand-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
                aria-label="View all service areas"
              >
                Service areas
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile stat row — shown below the grid on small screens -->
      <div
        class="lg:hidden mt-10 grid grid-cols-3 gap-px bg-white/10"
        aria-label="Company statistics"
      >
        {[
          { value: '15+',  label: 'Years'        },
          { value: '24/7', label: 'Available'    },
        ].map((stat) => (
          <div
            class="bg-white/10 flex flex-col items-center justify-center py-5 px-2 text-center"
            role="listitem"
            aria-label={`${stat.value} — ${stat.label}`}
          >
            <span class="font-display font-light text-white text-2xl leading-none mb-1">
              {stat.value}
            </span>
            <span class="font-sans text-[9px] font-medium tracking-[0.14em] uppercase text-white/50">
              {stat.label}
            </span>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════════════
     SERVICE AREAS — editorial map layout
     ════════════════════════════════════════════════════════════════════ -->
  <section
    class="relative bg-brand-forest overflow-hidden py-20 sm:py-28 px-6 sm:px-8"
    aria-labelledby="areas-heading"
  >

    <!-- Top gold rule -->
    <div
      class="absolute top-0 inset-x-0 h-px pointer-events-none"
      style="background: linear-gradient(90deg, transparent, rgba(195,154,69,0.45), transparent);"
      aria-hidden="true"
    ></div>

    <!-- Subtle texture -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[.03]"
      style="background-image: repeating-linear-gradient(45deg,#fff 0px,#fff 1px,transparent 1px,transparent 8px);"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-6xl mx-auto">

      <!-- ── Header row ── -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 lg:gap-16 items-end mb-16 sm:mb-20">
        <div>
          <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold mb-4">
            Coverage
          </p>
          <h2
            id="areas-heading"
            class="font-display font-light text-white leading-[1.04] tracking-[-0.025em]"
            style="font-size: clamp(2.25rem, 5vw, 4rem);"
          >
            Greater Seattle&nbsp;&mdash;<br>
            <em
              class="not-italic"
              style="font-style: italic !important; color: rgba(195,154,69,0.85);"
            >
              end to end
            </em>.
          </h2>
        </div>

        
        <a  href="/locations"
          class="ecl-focusable shrink-0 inline-flex items-center gap-2 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase text-white/60 border-b border-white/20 pb-1 transition-colors hover:text-brand-gold hover:border-brand-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest self-end"
          aria-label="View all service area locations"
        >
          All locations
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- ── Three-county columns ── -->
      <div
        class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-white/[.06] mb-14"
        role="list"
        aria-label="Service area counties"
      >
        {[
          {
            county: 'King County',
            note:   'incl. SeaTac Airport',
            cities: ['Seattle','Bellevue','Redmond','Kirkland','Renton','Auburn','Federal Way','Sammamish','Kenmore','Bothell','SeaTac','Tukwila','Mercer Island','Issaquah','Burien'],
          },
          {
            county: 'Snohomish County',
            note:   'incl. Paine Field',
            cities: ['Everett','Lynnwood','Edmonds','Mukilteo','Marysville','Mountlake Terrace','Shoreline','Woodinville','Mill Creek','Snohomish','Monroe','Arlington','Bothell North'],
          },
          {
            county: 'Pierce County',
            note:   'incl. Tacoma Dome',
            cities: ['Tacoma','Lakewood','Puyallup','Gig Harbor','Bonney Lake','Sumner','Fife','Milton','Edgewood','University Place','Steilacoom','DuPont'],
          },
        ].map((col) => (
          <div
            class="group relative bg-brand-forest px-7 py-8 sm:px-8 sm:py-10 transition-colors duration-300 hover:bg-white/[.04]"
            role="listitem"
            aria-label={`${col.county} service area`}
          >
            <!-- Animated gold top hairline -->
            <span
              class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-brand-gold transition-transform duration-500 ease-out group-hover:scale-x-100"
              aria-hidden="true"
            ></span>

            <!-- County heading -->
            <div class="flex items-start justify-between gap-4 mb-6">
              <div>
                <h3 class="font-display font-normal text-white text-xl leading-snug mb-1">
                  {col.county}
                </h3>
                <p class="font-sans text-[9px] font-medium tracking-[0.18em] uppercase text-brand-gold/70">
                  {col.note}
                </p>
              </div>
              <span
                class="shrink-0 mt-1 font-display font-light text-white/15 leading-none select-none"
                style="font-size: 2.5rem;"
                aria-hidden="true"
              >
                {col.cities.length}
              </span>
            </div>

            <!-- City list -->
            <ul
              class="list-none m-0 p-0 flex flex-col gap-2"
              aria-label={`Cities served in ${col.county}`}
            >
              {col.cities.map((city) => (
                <li class="flex items-center gap-2.5 font-sans font-light text-white/55 text-sm transition-colors duration-200 group-hover:text-white/65">
                  <span class="w-1 h-1 rounded-full bg-brand-gold/50 shrink-0" aria-hidden="true"></span>
                  {city}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- ── Chip strip ── -->
      <div class="flex flex-col items-center gap-6">
        <p class="font-sans text-[9px] font-medium tracking-[0.22em] uppercase text-white/30">
          All covered cities at a glance
        </p>

        <ul
          class="flex flex-wrap justify-center gap-2 list-none m-0 p-0"
          role="list"
          aria-label="All service area cities"
        >
          {areas.map((area) => (
            <li>
              <a
                href={area.href}
                class="inline-flex items-center px-3.5 py-1.5 font-sans text-[10px] sm:text-[11px] font-medium tracking-[0.08em] text-white/55 border border-white/10 transition-colors duration-300 hover:border-brand-gold/60 hover:text-white/80"
                role="listitem"
              >
                {area.name}
              </a>
            </li>
          ))}
        </ul>

        <p class="font-sans font-light text-white/30 text-xs text-center max-w-sm">
          Interstate transfers to Portland, OR and Vancouver, BC available on request.
        </p>
      </div>

    </div>

    <!-- Bottom gold rule -->
    <div
      class="absolute bottom-0 inset-x-0 h-px pointer-events-none"
      style="background: linear-gradient(90deg, transparent, rgba(195,154,69,0.25), transparent);"
      aria-hidden="true"
    ></div>

  </section>


  <!-- ════════════════════════════════════════════════════════════════════
     FINAL CTA — cream/champagne, editorial, restrained
     ════════════════════════════════════════════════════════════════════ -->
  <section
    class="relative bg-brand-champagne overflow-hidden py-20 sm:py-28 px-6 sm:px-8"
    aria-labelledby="cta-heading"
  >

    <!-- Top forest rule -->
    <div
      class="absolute top-0 left-0 right-0 h-px"
      style="background: linear-gradient(90deg, transparent, rgba(10,35,24,0.15), transparent);"
      aria-hidden="true"
    ></div>

    <!-- Subtle vertical spines — decorative only -->
    <div class="pointer-events-none absolute inset-y-0 left-1/4 w-px bg-brand-forest/[.05] hidden lg:block" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-y-0 right-1/4 w-px bg-brand-forest/[.05] hidden lg:block" aria-hidden="true"></div>

    <div class="relative z-10 max-w-6xl mx-auto">

      <!-- ── Asymmetric editorial grid ── -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-20 items-end">

        <!-- Left: heading block -->
        <div>
          <!-- Eyebrow with leading rule -->
          <div class="flex items-center gap-4 mb-6">
            <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
            <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
              Reserve Now
            </p>
          </div>

          <h2
            id="cta-heading"
            class="font-display font-light text-brand-forest leading-[1.04] tracking-[-0.025em] mb-6"
            style="font-size: clamp(2.5rem, 5.5vw, 4.5rem);"
          >
            Ready to ride<br>
            <em
              class="italic text-brand-gold"
            >
              in luxury?
            </em>
          </h2>

          <p class="font-sans font-light text-neutral-600 leading-relaxed max-w-lg"
            style="font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);">
            Book online in under 60 seconds — or speak to a chauffeur dispatcher 24&hairsp;/&hairsp;7.
          </p>
        </div>

        <!-- Right: action card -->
        <div class="shrink-0 w-full lg:w-[340px]">
          <div class="relative bg-white ring-1 ring-brand-forest/10 px-8 py-9">

            <!-- Animated gold hairline — consistent with card pattern -->
            <span
              class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-brand-gold transition-transform duration-700 ease-out"
              style="animation: scaleIn 1.2s cubic-bezier(0.25,0.46,0.45,0.94) 0.2s forwards;"
              aria-hidden="true"
            ></span>

            <!-- Reassurances -->
            <ul
              class="list-none m-0 p-0 flex flex-col gap-3 mb-8"
              aria-label="Booking reassurances"
            >
              {[
                'Flat-rate — your quote is your final charge',
                'Response within 60 minutes',
                'Free cancellation up to 4 hours prior',
              ].map((item) => (
                <li class="flex items-start gap-3 font-sans text-sm font-light text-neutral-600">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    width="14"
                    height="14"
                    class="shrink-0 mt-[2px] text-brand-gold"
                    aria-hidden="true"
                  >
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>

            <!-- Divider -->
            <div class="h-px bg-brand-forest/[.08] mb-8" aria-hidden="true"></div>

            <!-- Buttons -->
            <div
              class="flex flex-col gap-3"
              role="group"
              aria-label="Booking options"
            >
              
              <a  href="https://customer.moovs.app/a1-charters-1/new/info"
                target="_blank"
                rel="noopener noreferrer"
                data-cta="footer_book_now"
                aria-label="Reserve your ride — Emerald City Limos"
                class="ecl-btn-primary ecl-focusable inline-flex items-center justify-center gap-2 min-h-[52px] px-8 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase bg-brand-forest text-white border border-brand-forest rounded-none transition-colors duration-200 hover:bg-brand-forest/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
              >
                Reserve Your Ride
                <span aria-hidden="true" class="ecl-arrow transition-transform duration-200 group-hover:translate-x-0.5">→</span>
              </a>

              
              <a  href={PHONE_TEL}
                data-cta="footer_call_now"
                aria-label={`Call us at ${PHONE_DISPLAY}`}
                class="ecl-btn-secondary ecl-focusable inline-flex items-center justify-center gap-2.5 min-h-[52px] px-8 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase bg-transparent text-brand-forest border border-brand-forest/25 rounded-none transition-colors duration-200 hover:border-brand-gold hover:text-brand-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  width="14"
                  height="14"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                </svg>
                <span class="tabular-nums">{PHONE_DISPLAY}</span>
              </a>
            </div>

            <!-- Sub-note -->
            <p class="mt-5 font-sans text-[10px] font-light text-neutral-400 text-center tracking-[0.04em]">
              No payment until you confirm &middot; Corporate invoicing available
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom forest rule -->
    <div
      class="absolute bottom-0 left-0 right-0 h-px"
      style="background: linear-gradient(90deg, transparent, rgba(10,35,24,0.12), transparent);"
      aria-hidden="true"
    ></div>

  </section>

  <style>
    @keyframes scaleIn {
      from { transform: scaleX(0); }
      to   { transform: scaleX(1); }
    }
  </style>

</MainLayout>
