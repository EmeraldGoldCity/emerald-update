---
import MainLayout from '@/layouts/MainLayout.astro';
import {
  sanityClient,
  FEATURED_POST_QUERY,
  PAGINATED_POSTS_QUERY,
  POSTS_COUNT_QUERY,
  PAGE_SIZE,
} from '@/lib/sanity';
import type { NormalizedBlogPost } from '@/lib/sanity';
import FeaturedPost from '@/components/blog/FeaturedPost.astro';
import PostCard from '@/components/blog/PostCard.astro';
import Pagination from '@/components/blog/Pagination.astro';

export async function getStaticPaths() {
  const featuredPost = await sanityClient.fetch<NormalizedBlogPost | null>(FEATURED_POST_QUERY);
  const featuredId: string | null = featuredPost?._id ?? null;

  const totalCount = await sanityClient.fetch<number>(POSTS_COUNT_QUERY, { featuredId });
  const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));

  // Generate pages 2+ only; page 1 is /blog (index.astro).
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { featuredPost, featuredId, totalPages } as {
      featuredPost: NormalizedBlogPost | null;
      featuredId: string | null;
      totalPages: number;
    },
  }));
}

interface Props {
  featuredPost: NormalizedBlogPost | null;
  featuredId: string | null;
  totalPages: number;
}

const { page } = Astro.params;
const { featuredPost, featuredId, totalPages } = Astro.props;
const pageNum = parseInt(page!, 10);

const start = (pageNum - 1) * PAGE_SIZE;
const end = pageNum * PAGE_SIZE;

const posts = await sanityClient.fetch<NormalizedBlogPost[]>(PAGINATED_POSTS_QUERY, {
  featuredId,
  start,
  end,
});
---

<MainLayout
  title={`Blog — Page ${pageNum} | Emerald City Limos`}
  description="Travel tips, chauffeur insights, and luxury transportation guides for Seattle, Bellevue, and the greater Pacific Northwest."
  canonical={`https://emeraldcitylimos.com/blog/page/${pageNum}`}
>

  <!-- ── Hero ────────────────────────────────────────────────────────── -->
  <section class="bg-brand-forest py-16 sm:py-20 px-6 sm:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-4 mb-6">
        <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
        <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
          Insights & Guides
        </p>
      </div>
      <h1
        class="font-display font-light text-white leading-[1.08] tracking-[-0.025em] max-w-2xl"
        style="font-size: clamp(2rem, 4vw, 3.25rem);"
      >
        The Emerald City Limos
        <em class="italic text-brand-gold"> Journal</em>
      </h1>
      <p class="mt-4 font-sans font-light text-white/50 text-sm leading-relaxed max-w-lg">
        Travel tips, airport guides, and chauffeur insights for Seattle's most demanding travellers.
      </p>
    </div>
  </section>

  <!-- ── Featured Post (shown on every page for discoverability) ───── -->
  {featuredPost && (
    <section class="bg-white pt-12 pb-0 px-6 sm:px-8" aria-label="Featured article">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-6">
          <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
          <p class="font-sans text-[10px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
            Featured
          </p>
        </div>
        <FeaturedPost post={featuredPost} />
      </div>
    </section>
  )}

  <!-- ── Post grid ─────────────────────────────────────────────────── -->
  <section class="bg-white py-16 sm:py-20 px-6 sm:px-8" aria-label={`Blog posts — page ${pageNum}`}>
    <div class="max-w-6xl mx-auto">

      {posts.length > 0 ? (
        <>
          <ul
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"
            role="list"
          >
            {posts.map((post) => (
              <li role="listitem">
                <PostCard post={post} />
              </li>
            ))}
          </ul>
          <Pagination currentPage={pageNum} totalPages={totalPages} />
        </>
      ) : (
        <p class="font-sans text-neutral-400 text-center py-20">No posts on this page.</p>
      )}

    </div>
  </section>

</MainLayout>
