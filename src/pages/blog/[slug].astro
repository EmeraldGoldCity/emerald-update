---
import MainLayout from '@/layouts/MainLayout.astro';
import { BlogPostPage } from '@/app/pages/BlogPostPage';

export async function getStaticPaths() {
  const { blogContent } = await import('@/app/pages/BlogPostPage');
  return Object.keys(blogContent).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
---
<MainLayout
  title="Blog | Emerald City Limos"
  description="Seattle limo service tips, guides and news from Emerald City Limos."
>
  <BlogPostPage slug={slug} client:load />
</MainLayout>