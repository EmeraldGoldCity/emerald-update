---
/**
 * src/pages/about.astro
 * Emerald City Limos — About Us (modernized)
 *
 * Stack    : Astro · TypeScript · Tailwind CSS
 * Structure: MainLayout, PageHero, TrustStrip, brand-* tokens.
 *
 * Sections:
 *   1. PageHero + TrustStrip
 *   2. Origin Story       — asymmetric large-type + overlapping image card
 *   3. Stats Rail         — oversized numbers, staggered vertical rhythm
 *   4. Core Values        — full-bleed alternating rows, not cards
 *   5. Team               — editorial portrait + floating standards panel
 *   6. Service Areas      — dark, three-column linked city lists
 *   7. Credentials        — timeline-style numbered rows
 *   8. Testimonials       — large quote pull + two supporting cards
 *   9. Final CTA          — champagne, asymmetric, action card right
 */

import MainLayout from '@/layouts/MainLayout.astro';
import PageHero   from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
import { cityHref } from '@/data/locationSlugs';
import aboutHero   from '@/assets/images/about/about.png';
import aboutUs from "@/assets/images/about/about-us.png";

// ── Types ──────────────────────────────────────────────────────────────
interface Stat       { value: string; suffix: string; label: string; sub: string; }
interface Value      { number: string; title: string; body: string; }
interface TeamMember { name: string; role: string; image: string; imageAlt: string; }
interface County     { name: string; note: string; href: string; cities: readonly string[]; }
interface Credential { index: string; title: string; issuer: string; detail: string; }
interface Testimonial{ quote: string; author: string; location: string; tripType: string; rating: number; }

// ── Constants ──────────────────────────────────────────────────────────
const PHONE_DISPLAY = '(206) 595-9675';
const PHONE_TEL     = 'tel:+12065959675';

// ── Data ───────────────────────────────────────────────────────────────
const stats: Stat[] = [
  { value: '15',  suffix: '+',  label: 'Years in Operation',   sub: 'Founded Seattle, 2010'   },
  { value: '12',  suffix: 'k+', label: 'Rides Completed',      sub: 'And counting'             },
  // { value: '4.9', suffix: '★',  label: 'Google Rating',        sub: 'Verified reviews'         },
  { value: '3',   suffix: '',   label: 'Counties Served',      sub: 'King · Snohomish · Pierce'},
];

const values: Value[] = [
  {
    number: '01',
    title:  'Punctuality as a Promise',
    body:   'We track every flight, monitor every route, and buffer every schedule. Your time is the one thing we can never give back — so we protect it unconditionally.',
  },
  {
    number: '02',
    title:  'Discretion Above All',
    body:   "Our chauffeurs understand that the best ride is one the client barely notices. No unsolicited conversation, no phone calls on speaker, no commentary on your journey.",
  },
  {
    number: '03',
    title:  'Transparent by Design',
    body:   'Flat-rate pricing, published in advance, with no surge fees and no hidden tolls. What you quote is what you pay — every time, without exception.',
  },
];

const team: TeamMember[] = [
  {
    name:     'Kenneth Waweru',
    role:     'Founder & Lead Chauffeur',
    image:    '/images/team/kenneth-waweru.webp',
    imageAlt: 'Kenneth Waweru, founder of Emerald City Limos, standing beside a black Cadillac Escalade in Seattle',
  },
];

const chauffeurStandards: string[] = [
  'Washington State For-Hire Endorsement',
  'Clean DMV record — reviewed annually',
  'Comprehensive background check via third-party screener',
  'Drug & alcohol screening pre-hire and on rotation',
  'SeaTac terminal, cell-lot, and meet & greet protocol training',
  'ECL vehicle presentation standards — interior and exterior',
  'Executive hospitality and discretion briefing',
  'Emergency and inclement weather response training',
];

const counties: County[] = [
  {
    name:  'King County',
    note:  'incl. SeaTac Airport',
    href:  '/locations/king-county',
    cities: [
      'Seattle','Bellevue','Redmond','Kirkland','Renton',
      'Auburn','Federal Way','Sammamish','Kent','Bothell',
      'SeaTac Airport','Shoreline','Woodinville',
    ],
  },
  {
    name:  'Snohomish County',
    note:  'incl. Paine Field',
    href:  '/locations/snohomish-county',
    cities: [
      'Everett','Lynnwood','Edmonds','Mukilteo','Marysville',
      'Mountlake Terrace','Mill Creek','Snohomish','Monroe','Arlington',
    ],
  },
  {
    name:  'Pierce County',
    note:  'incl. Tacoma Dome',
    href:  '/locations/pierce-county',
    cities: [
      'Tacoma','Lakewood','Puyallup','Gig Harbor','Bonney Lake',
      'Sumner','Fife','University Place','Steilacoom','DuPont',
    ],
  },
];

const credentials: Credential[] = [
  {
    index:  '01',
    title:  'Washington State For-Hire License',
    issuer: 'WA Utilities & Transportation Commission',
    detail: 'All vehicles and operators are fully licenced under WA UTC regulations for commercial passenger transport.',
  },
  {
    index:  '02',
    title:  'Commercial Vehicle Insurance',
    issuer: 'Verified Carrier',
    detail: 'Every vehicle carries commercial-grade liability coverage exceeding Washington State minimums for passenger-carrying vehicles.',
  },
  {
    index:  '03',
    title:  'Background-Verified Chauffeurs',
    issuer: 'Third-Party Screening',
    detail: 'All drivers undergo comprehensive criminal background checks, DMV record reviews, and drug screening prior to their first assignment.',
  },
  {
    index:  '04',
    title:  'National Limousine Association',
    issuer: 'NLA Member',
    detail: "Active membership in the industry's foremost professional body for standards, ethics, and operator accountability.",
  },
];


---

<MainLayout
  title="About Emerald City Limos | Seattle Chauffeur Service Since 2010"
  description="The story behind Emerald City Limos — Seattle's trusted black car service since 2010. Meet our founder, chauffeur standards, service area, and the values that define every ride."
  keywords="about emerald city limos, seattle chauffeur company, seattle black car service history, seatac limo founder"
>

  <!-- ════════════════════════════════════════════════════════════════════
       1. HERO + TRUST STRIP
       ════════════════════════════════════════════════════════════════════ -->
  <PageHero
    eyebrow="Our Story — Established Seattle, 2010"
    headline="Built on a Standard"
    headlineAccent="Seattle Deserved"
    supporting="Emerald City Limos was founded on a single conviction: that the Pacific Northwest's most demanding travellers deserved a chauffeur service that treated reliability, discretion, and transparency as non-negotiable minimums — not premium add-ons."
    ctaPrimary={{ label: 'Reserve Your Ride', href: 'https://customer.moovs.app/a1-charters-1/new/info', id: 'cta-about-book' }}
    ctaSecondary={{ label: PHONE_DISPLAY, href: PHONE_TEL, id: 'cta-about-call', phone: PHONE_DISPLAY }}
    image={{
      src:       aboutHero,
      srcMobile: aboutHero,
      alt:       'Emerald City Limos founder beside a black Cadillac Escalade with the Seattle skyline visible in the background',
      width:     1672,
      height:    941,
    }}
    size="full"
    id="about-hero-heading"
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
  />
  <TrustStrip />


  <!-- ════════════════════════════════════════════════════════════════════
       2. ORIGIN STORY — asymmetric oversized type + overlapping image card
       ════════════════════════════════════════════════════════════════════ -->
  <section
    class="relative bg-brand-champagne overflow-hidden py-16 sm:py-24 px-6 sm:px-8"
    aria-labelledby="origin-heading"
  >
    <!-- Vertical spine -->
    <div class="pointer-events-none absolute left-0 inset-y-0 w-px bg-brand-forest/[.06] hidden lg:block" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto">

      <!-- Running label row -->
      <div class="flex items-center justify-between mb-10 sm:mb-12">
        <div class="flex items-center gap-4">
          <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
          <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
            Why We Started
          </p>
        </div>
        <p class="hidden sm:block font-sans text-[11px] font-medium tracking-[0.16em] uppercase text-brand-forest/30">
          Seattle, WA &mdash; Est. 2010
        </p>
      </div>

      <!-- Section heading — refined scale -->
      <h2
        id="origin-heading"
        class="font-display font-light text-brand-forest leading-[1.08] tracking-[-0.025em] mb-10 sm:mb-12 max-w-2xl"
        style="font-size: clamp(1.875rem, 3.5vw, 2.75rem);"
      >
        A decade behind the wheel
        <em
          class="text-brand-gold"
        >
          &mdash; before the first booking.
        </em>
      </h2>

      <!-- Two-column: copy left, image right (overlapping card layout) -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-0 lg:gap-0 items-start">

        <!-- Left: prose + quote -->
        <div class="lg:pr-16 pb-12 lg:pb-0">
          <div class="space-y-5 mb-8">
            <p class="font-sans text-sm leading-[1.8] text-neutral-600 max-w-lg">
              Before Emerald City Limos existed, Kenneth Waweru spent ten years behind the wheel for Seattle's executive hospitality sector — hotels, law firms, tech campuses, and the city's busiest corporate travel desks.
            </p>
            <p class="font-sans text-sm leading-[1.8] text-neutral-600 max-w-lg">
              In 2010, he started ECL with one Cadillac Escalade, a published flat-rate schedule, and a commitment that every driver who wore the ECL badge would meet a standard he'd be comfortable sitting behind himself. That standard hasn't changed.
            </p>
            <p class="font-sans text-sm leading-[1.8] text-neutral-600 max-w-lg">
              Today ECL serves King, Snohomish, and Pierce counties. Every vehicle is owned by ECL. Every chauffeur is a W-2 employee. Every quote is flat-rate with zero surge logic.
            </p>
          </div>

          <!-- Pull quote -->
          <blockquote
            class="border-l-2 border-brand-gold pl-5 mb-8"
            cite="https://emeraldcitylimos.com/about"
          >
            <p
              class="font-display italic text-brand-forest leading-[1.5]"
              style="font-size: clamp(1rem, 1.6vw, 1.25rem); font-style: italic;"
            >
              "If I wouldn't feel confident putting my own mother in that car, it doesn't leave the garage."
            </p>
            <footer class="mt-4">
              <cite class="font-sans not-italic text-sm font-medium tracking-[0.06em] text-brand-gold">
                — Kenneth Waweru, Founder
              </cite>
            </footer>
          </blockquote>

        </div>

        <!-- Right: image with overlapping year badge and floating stat card -->
        <div class="relative lg:-mt-32">
          <!-- Corner accents -->
          <div class="absolute -top-3 -left-3 w-12 h-12 border-l border-t border-brand-gold/50 pointer-events-none" aria-hidden="true"></div>
          <div class="absolute -bottom-3 -right-3 w-12 h-12 border-r border-b border-brand-gold/25 pointer-events-none" aria-hidden="true"></div>

          <img
            src={aboutUs.src}
            alt="Emerald City Limos founder Kenneth Waweru beside a black Cadillac Escalade in downtown Seattle"
            width="800"
            height="960"
            loading="lazy"
            decoding="async"
            class="relative w-full h-[480px] sm:h-[580px] lg:h-[680px] object-cover object-top"
          />

          <!-- Est. badge — bottom-left of image -->
          <div
            class="absolute bottom-6 left-6 bg-brand-forest px-5 py-4 flex flex-col gap-0.5"
            role="img"
            aria-label="Established 2010"
          >
            <span class="font-display font-light text-white leading-none" style="font-size: 2.25rem;">2010</span>
            <span class="font-sans text-[9px] font-semibold tracking-[0.22em] uppercase text-brand-gold">Est. Seattle</span>
          </div>

          <!-- Floating stat card — overlaps image bottom-right -->
          <div
            class="absolute -bottom-6 -right-4 lg:-right-10 bg-white ring-1 ring-brand-forest/10 px-6 py-5 w-48"
            aria-label="12,000 rides completed"
          >
            <span
              class="block font-display font-light text-brand-forest leading-none mb-1"
              style="font-size: 1.25rem;"
            >
              12k+
            </span>
            <span class="font-sans text-[10px] font-medium tracking-[0.16em] uppercase text-brand-gold">
              Rides completed
            </span>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════════════
       3. STATS RAIL — oversized numbers, sub-labels, staggered feel
       ════════════════════════════════════════════════════════════════════ -->
  <section
    class="bg-brand-forest px-6 sm:px-8"
    aria-label="Emerald City Limos by the numbers"
  >
    <ul
      class="max-w-6xl mx-auto flex  justify-around list-none m-0 p-0"
      role="list"
    >
      {stats.map((stat) => (
        <li
          class="group flex items-center gap-4 bg-brand-forest px-6 py-5 sm:px-8 sm:py-6 transition-colors duration-300 hover:bg-white/[.04]"
          role="listitem"
          aria-label={`${stat.value}${stat.suffix} — ${stat.label}`}
        >
          <span
            class="font-display font-light leading-none shrink-0 transition-colors duration-300 group-hover:text-brand-gold"
            style="font-size: clamp(1.375rem, 2vw, 1.75rem); color: rgba(195,154,69,0.85);"
          >
            {stat.value}{stat.suffix}
          </span>
          <div class="flex flex-col gap-0.5 min-w-0">
            <span class="font-sans text-[10px] font-semibold tracking-[0.16em] uppercase text-white truncate">
              {stat.label}
            </span>
            <span class="font-sans text-[9px] font-light tracking-[0.06em] text-white/30">
              {stat.sub}
            </span>
          </div>
        </li>
      ))}
    </ul>
  </section>


  <!-- ════════════════════════════════════════════════════════════════════
       4. CORE VALUES — full-bleed alternating rows, not cards
       ════════════════════════════════════════════════════════════════════ -->
  <section
    class="bg-white py-14 sm:py-20 px-6 sm:px-8"
    aria-labelledby="values-heading"
  >
    <div class="max-w-6xl mx-auto">

      <!-- Header row -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 items-end mb-10 sm:mb-12 pb-10 border-b border-brand-forest/[.08]">
        <div>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-widest text-brand-gold mb-3">
            What We Stand For
          </p>
          <h2
            id="values-heading"
            class="font-display font-light text-brand-forest leading-[1.08] tracking-[-0.02em]"
            style="font-size: clamp(1.625rem, 3vw, 2.25rem);"
          >
            Three principles we
            <em class="text-brand-gold">
              don't negotiate on
            </em>.
          </h2>
        </div>
        <p class="font-sans text-sm font-light text-neutral-500 leading-relaxed lg:max-w-sm lg:ml-auto">
          These aren't marketing claims. They're operational commitments baked into every booking, every chauffeur hire, and every vehicle we put on the road.
        </p>
      </div>

      <!-- Value rows -->
      <ol class="list-none m-0 p-0 flex flex-col" role="list" aria-label="Core company values">
        {values.map((v, i) => (
          <li
            class:list={[
              'group grid grid-cols-1 lg:grid-cols-[56px_1fr_1fr] gap-6 lg:gap-10 items-start py-8 border-b border-brand-forest/[.08] transition-colors duration-300 hover:bg-brand-champagne/40 -mx-6 sm:-mx-8 px-6 sm:px-8',
              i === 0 && 'border-t border-t-brand-forest/[.08]',
            ]}
            role="listitem"
          >
            <span
              class="font-display font-light text-brand-forest/20 leading-none transition-colors duration-300 group-hover:text-brand-gold/40"
              style="font-size: clamp(1rem, 1.5vw, 1.25rem);"
              aria-hidden="true"
            >
              {v.number}
            </span>
            <h3
              class="font-display font-light text-brand-forest leading-[1.2] transition-colors duration-300"
              style="font-size: clamp(1.125rem, 1.8vw, 1.375rem);"
            >
              {v.title}
            </h3>
            <p class="font-sans font-light text-neutral-600 leading-[1.8] text-sm sm:text-base">
              {v.body}
            </p>
          </li>
        ))}
      </ol>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════════════
       5. TEAM — editorial portrait + floating standards panel
       ════════════════════════════════════════════════════════════════════ -->
  <section
    id="team"
    class="relative bg-brand-champagne overflow-hidden py-14 sm:py-20 px-6 sm:px-8"
    aria-labelledby="team-heading"
  >
    <div class="max-w-6xl mx-auto">

      <!-- Section label -->
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
        <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
          Our People
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- Portrait column -->
        <div class="relative">
          {team.map((member) => (
            <article aria-label={`${member.name} — ${member.role}`}>
              <div class="relative overflow-hidden group">
                <img
                  src={member.image}
                  alt={member.imageAlt}
                  width="480"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-[360px] sm:h-[440px] object-cover object-top
                         transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                />
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-brand-forest/85 via-brand-forest/20 to-transparent pointer-events-none"></div>
                <!-- Name plate -->
                <div class="absolute bottom-0 inset-x-0 px-6 py-6">
                  <p class="font-sans text-[9px] font-semibold tracking-[0.24em] uppercase text-brand-gold mb-1.5">
                    {member.role}
                  </p>
                  <h3 class="font-display font-light text-white leading-none" style="font-size: 1.375rem;">
                    {member.name}
                  </h3>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Standards column -->
        <div class="lg:pt-4">
          <h2
            id="team-heading"
            class="font-display font-light text-brand-forest leading-[1.08] tracking-[-0.02em] mb-5"
            style="font-size: clamp(1.5rem, 2.8vw, 2rem);"
          >
            The ECL chauffeur
            <em
              class="text-brand-gold"
            >
              standard.
            </em>
          </h2>

          <p class="font-sans text-sm leading-[1.8] text-neutral-600 mb-7 max-w-lg">
            Every chauffeur at Emerald City Limos is an employee — not a contractor, not a platform driver. Before their first booking they complete our in-house onboarding, which covers:
          </p>

          <!-- Checklist — two columns, clean rows -->
          <ul
            class="list-none m-0 p-0 flex flex-col gap-0"
            aria-label="Chauffeur qualification requirements"
          >
            {chauffeurStandards.map((item, i) => (
              <li
                class:list={[
                  'group flex items-start gap-4 py-4 border-b border-brand-forest/[.08] transition-colors duration-200 hover:bg-brand-gold/[.04] -mx-4 px-4',
                  i === 0 && 'border-t border-t-brand-forest/[.08]',
                ]}
              >
                <span
                  class="shrink-0 mt-0.5 inline-flex h-5 w-5 items-center justify-center bg-white ring-1 ring-brand-forest/10 transition-all duration-200 group-hover:ring-brand-gold"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="11" height="11" class="text-brand-gold" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                </span>
                <span class="font-sans text-sm leading-[1.65] text-neutral-700 group-hover:text-brand-forest transition-colors duration-200">
                  {item}
                </span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════════════
       6. SERVICE AREAS — dark, editorial three-column linked city lists
       ════════════════════════════════════════════════════════════════════ -->
  <section
    class="relative bg-brand-forest overflow-hidden py-14 sm:py-20 px-6 sm:px-8"
    aria-labelledby="areas-heading"
  >
    <div
      class="absolute top-0 inset-x-0 h-px pointer-events-none"
      style="background: linear-gradient(90deg, transparent, rgba(195,154,69,0.45), transparent);"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 opacity-[.025]"
      style="background-image: repeating-linear-gradient(45deg,#fff 0px,#fff 1px,transparent 1px,transparent 8px);"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-6xl mx-auto">

      <!-- Header -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 items-end mb-10 sm:mb-12">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
            <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
              Coverage
            </p>
          </div>
          <h2
            id="areas-heading"
            class="font-display font-light text-white leading-[1.08] tracking-[-0.02em]"
            style="font-size: clamp(1.625rem, 3vw, 2.25rem);"
          >
            Greater Seattle &mdash;
            <em
              class="not-italic"
              style="font-style: italic !important; color: rgba(195,154,69,0.75);"
            >
              end to end
            </em>.
          </h2>
        </div>
        <a
          href="/locations"
          class="ecl-focusable shrink-0 self-end inline-flex items-center gap-2 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase text-white/50 border-b border-white/20 pb-1 transition-colors hover:text-brand-gold hover:border-brand-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
          aria-label="View all service area locations"
        >
          All locations
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Three-county columns -->
      <div
        class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-white/[.06] mb-14"
        role="list"
        aria-label="Service area counties"
      >
        {counties.map((col) => (
          <div
            class="group relative bg-brand-forest px-6 py-7 sm:px-7 sm:py-8 transition-colors duration-300 hover:bg-white/[.04]"
            role="listitem"
            aria-label={`${col.name} service area`}
          >
            <span
              class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-brand-gold transition-transform duration-500 ease-out group-hover:scale-x-100"
              aria-hidden="true"
            ></span>

            <!-- County heading -->
            <div class="flex items-start justify-between gap-4 mb-5">
              <div>
                <a
                  href={col.href}
                  class="ecl-focusable group/link inline-block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest"
                  aria-label={`View all ${col.name} chauffeur service locations`}
                >
                  <h3 class="font-display font-normal text-white text-base leading-snug mb-1 transition-colors duration-200 group-hover/link:text-brand-gold">
                    {col.name}
                  </h3>
                </a>
                <p class="font-sans text-[9px] font-medium tracking-[0.18em] uppercase text-brand-gold/60">
                  {col.note}
                </p>
              </div>
              <span
                class="shrink-0 mt-0.5 font-display font-light text-white/10 leading-none select-none text-2xl"
                aria-hidden="true"
              >
                {col.cities.length}
              </span>
            </div>

            <!-- City links -->
            <ul
              class="list-none m-0 p-0 flex flex-col gap-1.5"
              aria-label={`Cities served in ${col.name}`}
            >
              {col.cities.map((city) => (
                <li>
                  <a
                    href={cityHref(city)}
                    class="ecl-focusable group/city flex items-center gap-2.5 font-sans font-light text-white/45 text-sm transition-colors duration-200 hover:text-white focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-gold focus-visible:ring-offset-1 focus-visible:ring-offset-brand-forest"
                    aria-label={`Chauffeur service in ${city}`}
                  >
                    <span class="w-1 h-1 rounded-full bg-brand-gold/35 shrink-0 transition-colors duration-200 group-hover/city:bg-brand-gold" aria-hidden="true"></span>
                    {city}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="font-sans font-light text-white/25 text-xs text-center">
        Interstate transfers to Portland, OR and Vancouver, BC available on request.
      </p>
    </div>

    <div
      class="absolute bottom-0 inset-x-0 h-px pointer-events-none"
      style="background: linear-gradient(90deg, transparent, rgba(195,154,69,0.2), transparent);"
      aria-hidden="true"
    ></div>
  </section>


  <!-- ════════════════════════════════════════════════════════════════════
       7. CREDENTIALS — timeline-style, two-column sticky header
       ════════════════════════════════════════════════════════════════════ -->
  <section
    class="bg-white py-14 sm:py-20 px-6 sm:px-8"
    aria-labelledby="creds-heading"
  >
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-10 lg:gap-16 items-start">

      <!-- Sticky header -->
      <div class="lg:sticky lg:top-28">
        <div class="flex items-center gap-4 mb-5">
          <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
          <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
            Credentials
          </p>
        </div>
        <h2
          id="creds-heading"
          class="font-display font-light text-brand-forest leading-[1.08] tracking-[-0.02em] mb-4"
          style="font-size: clamp(1.375rem, 2.5vw, 1.875rem);"
        >
          Licenced, insured,
          <em
            class="text-brand-gold"
          >
            and accountable.
          </em>
        </h2>
        <p class="font-sans font-light text-neutral-500 leading-relaxed text-sm">
          Every credential is current, verified, and available for review on request.
        </p>
      </div>

      <!-- Timeline list -->
      <ul
        class="list-none m-0 p-0 flex flex-col"
        role="list"
        aria-label="Professional credentials and certifications"
      >
        {credentials.map((cred, i) => (
          <li
            class:list={[
              'group relative flex gap-5 items-start py-6 border-b border-brand-forest/[.08] transition-colors duration-200 hover:bg-brand-champagne/60 -mx-4 px-4',
              i === 0 && 'border-t border-t-brand-forest/[.08]',
            ]}
            role="listitem"
          >
            <span
              class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-brand-gold transition-transform duration-500 ease-out group-hover:scale-x-100"
              aria-hidden="true"
            ></span>
            <span
              class="shrink-0 pt-0.5 font-display font-light text-[0.75rem] tracking-[0.12em] transition-colors duration-200 group-hover:text-brand-gold"
              style="color: rgba(195,154,69,0.4);"
              aria-hidden="true"
            >
              {cred.index}
            </span>
            <div>
              <h3 class="font-display font-medium text-brand-forest text-base leading-[1.3] mb-1 transition-colors duration-200">
                {cred.title}
              </h3>
              <p class="font-sans text-[9px] font-semibold tracking-[0.2em] uppercase text-brand-gold mb-2">
                {cred.issuer}
              </p>
              <p class="font-sans font-light text-neutral-500 text-sm leading-[1.75]">
                {cred.detail}
              </p>
            </div>
          </li>
        ))}
      </ul>

    </div>
  </section>


 

  <!-- ════════════════════════════════════════════════════════════════════
       9. FINAL CTA — champagne, asymmetric, action card right
       ════════════════════════════════════════════════════════════════════ -->
   <section
    class="relative bg-brand-champagne overflow-hidden py-20 sm:py-28 px-6 sm:px-8"
    aria-labelledby="cta-heading"
  >

    <!-- Top forest rule -->
    <div
      class="absolute top-0 left-0 right-0 h-px"
      style="background: linear-gradient(90deg, transparent, rgba(10,35,24,0.15), transparent);"
      aria-hidden="true"
    ></div>

    <!-- Subtle vertical spines — decorative only -->
    <div class="pointer-events-none absolute inset-y-0 left-1/4 w-px bg-brand-forest/[.05] hidden lg:block" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-y-0 right-1/4 w-px bg-brand-forest/[.05] hidden lg:block" aria-hidden="true"></div>

    <div class="relative z-10 max-w-6xl mx-auto">

      <!-- ── Asymmetric editorial grid ── -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-20 items-end">

        <!-- Left: heading block -->
        <div>
          <!-- Eyebrow with leading rule -->
          <div class="flex items-center gap-4 mb-6">
            <div class="h-px w-10 bg-brand-gold shrink-0" aria-hidden="true"></div>
            <p class="font-sans text-[10px] sm:text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-gold">
              Reserve Now
            </p>
          </div>

          <h2
            id="cta-heading"
            class="font-display font-light text-brand-forest leading-[1.04] tracking-[-0.025em] mb-6"
            style="font-size: clamp(2.5rem, 5.5vw, 4.5rem);"
          >
            Experience the standard<br>
            <em
              class="italic text-brand-gold"
            >
              for your self?
            </em>
          </h2>

          <p class="font-sans font-light text-neutral-600 leading-relaxed max-w-lg"
            style="font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);">
            Book online in under 60 seconds — or speak to a chauffeur dispatcher 24&hairsp;/&hairsp;7.
          </p>
        </div>

        <!-- Right: action card -->
        <div class="shrink-0 w-full lg:w-[340px]">
          <div class="relative bg-white ring-1 ring-brand-forest/10 px-8 py-9">

            <!-- Animated gold hairline — consistent with card pattern -->
            <span
              class="absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-brand-gold transition-transform duration-700 ease-out"
              style="animation: scaleIn 1.2s cubic-bezier(0.25,0.46,0.45,0.94) 0.2s forwards;"
              aria-hidden="true"
            ></span>

            <!-- Reassurances -->
            <ul
              class="list-none m-0 p-0 flex flex-col gap-3 mb-8"
              aria-label="Booking reassurances"
            >
              {[
                'Flat-rate — your quote is your final charge',
                'Response within 60 minutes',
                'Free cancellation up to 4 hours prior',
              ].map((item) => (
                <li class="flex items-start gap-3 font-sans text-sm font-light text-neutral-600">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    width="14"
                    height="14"
                    class="shrink-0 mt-[2px] text-brand-gold"
                    aria-hidden="true"
                  >
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>

            <!-- Divider -->
            <div class="h-px bg-brand-forest/[.08] mb-8" aria-hidden="true"></div>

            <!-- Buttons -->
            <div
              class="flex flex-col gap-3"
              role="group"
              aria-label="Booking options"
            >
              
              <a  href="https://customer.moovs.app/a1-charters-1/new/info"
                target="_blank"
                rel="noopener noreferrer"
                data-cta="footer_book_now"
                aria-label="Reserve your ride — Emerald City Limos"
                class="ecl-btn-primary ecl-focusable inline-flex items-center justify-center gap-2 min-h-[52px] px-8 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase bg-brand-forest text-white border border-brand-forest rounded-none transition-colors duration-200 hover:bg-brand-forest/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
              >
                Reserve Your Ride
                <span aria-hidden="true" class="ecl-arrow transition-transform duration-200 group-hover:translate-x-0.5">→</span>
              </a>

              
              <a  href={PHONE_TEL}
                data-cta="footer_call_now"
                aria-label={`Call us at ${PHONE_DISPLAY}`}
                class="ecl-btn-secondary ecl-focusable inline-flex items-center justify-center gap-2.5 min-h-[52px] px-8 font-sans text-[11px] font-semibold tracking-[0.2em] uppercase bg-transparent text-brand-forest border border-brand-forest/25 rounded-none transition-colors duration-200 hover:border-brand-gold hover:text-brand-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  width="14"
                  height="14"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                </svg>
                <span class="tabular-nums">{PHONE_DISPLAY}</span>
              </a>
            </div>

            <!-- Sub-note -->
            <p class="mt-5 font-sans text-[10px] font-light text-neutral-400 text-center tracking-[0.04em]">
              No payment until you confirm &middot; Corporate invoicing available
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom forest rule -->
    <div
      class="absolute bottom-0 left-0 right-0 h-px"
      style="background: linear-gradient(90deg, transparent, rgba(10,35,24,0.12), transparent);"
      aria-hidden="true"
    ></div>

  </section>

