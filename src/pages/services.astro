  {/* Why Choose Us */}
  <section class="py-20 bg-gradient-to-br from-emerald-900 to-emerald-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4">Why Emerald City Limos?</h2>
        <p class="text-xl text-gray-200">Excellence in every detail</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="text-4xl font-bold text-[#d4af37] mb-2">Stress-Free</div>
          <p class="text-xl">Chauffeured Transport</p>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-[#d4af37] mb-2">50K+</div>
          <p class="text-xl">Happy Customers</p>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-[#d4af37] mb-2">24/7</div>
