            </li>
          </ul>
          <a href="/service/cruise-transportation" class="inline-flex items-center justify-center text-emerald-700 font-semibold hover:text-emerald-800 transition-colors mt-auto">
            Learn More
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        {/* Infant Car Seats */}
        <div class="bg-white border-2 border-gray-200 rounded-xl p-6 hover:border-emerald-500 hover:shadow-xl transition-all flex flex-col h-full">
          <div class="flex items-center justify-center mb-4">
            <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-emerald-700 to-emerald-600 text-white rounded-lg flex items-center justify-center text-3xl">
              👶
            </div>
          </div>
          <h3 class="text-xl font-bold text-gray-900 text-center mb-3">Infant Car Seats/Booster Seats</h3>
          <p class="text-gray-700 text-sm mb-4 flex-grow">Travel safely with your little ones. Our vehicles come equipped with professionally installed infant car seats and booster seats appropriate for all ages.</p>
          <ul class="space-y-1.5 mb-4">
            <li class="flex items-center space-x-2 text-sm">
              <span class="text-[#d4af37]">•</span>
              <span class="text-gray-700">Pre-installed upon request</span>
            </li>
            <li class="flex items-center space-x-2 text-sm">
              <span class="text-[#d4af37]">•</span>
              <span class="text-gray-700">Multiple age groups</span>
            </li>
            <li class="flex items-center space-x-2 text-sm">
              <span class="text-[#d4af37]">•</span>
              <span class="text-gray-700">Safety certified</span>
            </li>
            <li class="flex items-center space-x-2 text-sm">
              <span class="text-[#d4af37]">•</span>
              <span class="text-gray-700">Complimentary service</span>
            </li>
          </ul>
          <a href="/service/infant-car-seats" class="inline-flex items-center justify-center text-emerald-700 font-semibold hover:text-emerald-800 transition-colors mt-auto">
            Learn More
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        {/* Personal Chauffeur */}
        <div class="bg-white border-2 border-gray-200 rounded-xl p-6 hover:border-emerald-500 hover:shadow-xl transition-all flex flex-col h-full">
          <div class="flex items-center justify-center mb-4">
            <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-emerald-700 to-emerald-600 text-white rounded-lg flex items-center justify-center text-3xl">
              🚗
            </div>
          </div>
          <h3 class="text-xl font-bold text-gray-900 text-center mb-3">Personal Chauffeur</h3>
          <p class="text-gray-700 text-sm mb-4 flex-grow">Dedicated chauffeur service tailored for clients seeking personalized transportation for their families and business needs. Your own professional driver, on your schedule.</p>
          <ul class="space-y-1.5 mb-4">
            <li class="flex items-center space-x-2 text-sm">
              <span class="text-[#d4af37]">•</span>
              <span class="text-gray-700">Dedicated driver</span>
            </li>
            <li class="flex items-center space-x-2 text-sm">
              <span class="text-[#d4af37]">•</span>
              <span class="text-gray-700">Flexible scheduling</span>
