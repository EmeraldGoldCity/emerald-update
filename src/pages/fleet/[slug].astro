---
/**
 * /fleet/[slug]
 * -------------
 * Dynamic vehicle detail page. One route file serves every vehicle in
 * src/data/fleet.ts. Adding a new vehicle to fleet.ts auto-creates the
 * matching detail page on the next build.
 *
 * Page structure
 *   1. PageHero        — vehicle image as LCP, name, capacity, description
 *   2. TrustStrip      — trust signals
 *   3. VehicleDetails  — gallery (left) + specs / features / CTA (right)
 *   4. VehicleStandards — detailing, inspection, licensing, chauffeur standards
 *   5. Closing CTA     — dark full-width conversion section
 *   6. VehicleSchema   — JSON-LD structured data (invisible)
 */
import type { ImageMetadata } from 'astro';
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
import VehicleDetails from '@/components/fleet/VehicleDetails.astro';
import VehicleStandards from '@/components/fleet/VehicleStandards.astro';
import VehicleSchema from '@/components/fleet/VehicleSchema.astro';
import { fleet, type Vehicle } from '@/data/fleet';

export async function getStaticPaths() {
  return fleet.map((vehicle) => ({
    params: { slug: vehicle.id },
    props: { vehicle },
  }));
}

interface Props {
  vehicle: Vehicle;
}

const { vehicle } = Astro.props;

const metaTitle = `${vehicle.name} Chauffeur Seattle | Emerald City Limos`;
const metaDescription =
  vehicle.description
    ? vehicle.description.slice(0, 155).replace(/\s+\S*$/, '') + '…'
    : `Chauffeured ${vehicle.name} (${vehicle.category}) in Seattle — ${vehicle.capacityLabel}. Licensed Washington carrier, $1.5M insured, 24/7 dispatch.`;

/* Hero image — vehicle.imageSrc is ImageMetadata for all local fleet assets */
const heroImage = vehicle.imageSrc
  ? { src: vehicle.imageSrc as ImageMetadata, alt: vehicle.imageAlt }
  : undefined;
---

<MainLayout
  title={metaTitle}
  description={metaDescription}
  keywords={`${vehicle.name.toLowerCase()} seattle, ${vehicle.category.toLowerCase()} chauffeur seattle, seattle limo fleet`}
>
  <!-- ── 1. Hero ──────────────────────────────────────────────── -->
  <PageHero
    eyebrow={vehicle.category}
    headline={vehicle.name}
    headlineAccent={vehicle.capacityLabel}
    supporting={vehicle.description ?? `${vehicle.category} for chauffeured service across the Seattle metro — ${vehicle.capacityLabel}. Detailed between every ride and licensed to operate in Washington State.`}
    ctaPrimary={{ label: 'Reserve this Vehicle', href: '/book-now', id: `cta-${vehicle.id}-book` }}
    image={heroImage}
    size="page"
    id={`${vehicle.id}-hero`}
    breadcrumbs={[{label:'Home',href:'/'},{label:'Fleet',href:'/fleet'},{label:vehicle.name}]}
  />

  <!-- ── 2. Trust strip ───────────────────────────────────────── -->
  <TrustStrip />

  <!-- ── 3. Gallery · Specs · Features ───────────────────────── -->
  <VehicleDetails vehicle={vehicle} />

  <!-- ── 4. Standards & care ─────────────────────────────────── -->
  <VehicleStandards vehicle={vehicle} />

  <!-- ── 5. Closing CTA ───────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-brand-forest-deep py-16 text-brand-champagne sm:py-20 lg:py-24"
    aria-labelledby={`cta-close-${vehicle.id}`}
  >
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 80% 50%, rgba(163,126,44,0.16) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-4xl px-6 text-center sm:px-8 lg:px-12">
      <div class="mb-3 flex items-center justify-center gap-3">
        <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
        <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-gold-soft">
          Reserve Now
        </p>
        <span class="h-px w-8 bg-brand-gold-soft" aria-hidden="true"></span>
      </div>

      <h2
        id={`cta-close-${vehicle.id}`}
        class="mb-4 font-display font-light leading-[1.1] text-white"
        style="font-size: clamp(1.85rem, 3.8vw, 2.6rem); letter-spacing: -0.01em;"
      >
        Book the {vehicle.name}
        <em class="italic text-brand-gold-soft">tonight.</em>
      </h2>

      <p class="mx-auto mb-8 max-w-xl font-sans text-[0.98rem] font-light leading-relaxed text-white/75">
        Dispatch is staffed 24/7. Book online in under two minutes or call —
        a human picks up.
      </p>

      <div
        class="flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center sm:gap-4"
        role="group"
        aria-label="Book or call"
      >
        <a
          href="/book-now"
          class="inline-flex min-h-[52px] items-center justify-center gap-2 border border-brand-gold-soft bg-brand-gold-soft px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-forest outline-none transition-[background-color,border-color,box-shadow] duration-200 hover:bg-brand-gold hover:shadow-[0_12px_28px_-12px_rgba(163,126,44,0.6)] focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest-deep motion-reduce:transition-none"
        >
          Reserve a Ride
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="tel:+12065959675"
          class="inline-flex min-h-[52px] items-center justify-center gap-2 border border-white/30 bg-transparent px-8 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-white outline-none transition-colors duration-200 hover:border-white/70 focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-forest-deep motion-reduce:transition-none"
          aria-label="Call Emerald City Limos at (206) 595-9675, available 24 hours"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            width="14"
            height="14"
            aria-hidden="true"
          >
            <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <span class="tabular-nums">(206) 595-9675</span>
        </a>
      </div>

      <p class="mt-6 font-sans text-[0.72rem] uppercase tracking-[0.18em] text-white/45">
        Licensed · Insured · 24/7 dispatch
      </p>
    </div>
  </section>

  <!-- ── 6. Structured data ───────────────────────────────────── -->
  <VehicleSchema vehicle={vehicle} />
</MainLayout>
