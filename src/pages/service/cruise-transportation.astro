---
import MainLayout from '@/layouts/MainLayout.astro';
import PageHero from '@/components/shared/PageHero.astro';
import TrustStrip from '@/components/shared/TrustStrip.astro';
---

<MainLayout
  title="Cruise Transportation - Emerald City Limos Seattle"
  description="Seamless transportation to Seattle cruise terminals at Pier 91 and Bell Street Pier. Start your voyage stress-free."
  keywords="cruise terminal transportation seattle, pier 91 limo service, bell street pier transportation, cruise port shuttle seattle"
>
  <PageHero
    eyebrow="Cruise Transfers"
    headline="Cruise"
    headlineAccent="Transportation"
    supporting="Door-to-pier service for Seattle cruise terminals at Pier 91 and Bell Street Pier. Luggage handled, timing planned around boarding windows — your voyage begins stress-free."
    ctaPrimary={{ label: 'Book Cruise Transfer', href: '/book-now', id: 'cta-cruise-book' }}
    image={{
      src: 'https://images.unsplash.com/photo-1488085061387-422e29b40080?w=1920&h=1080&fit=crop&q=80',
      alt: 'Cruise ship docked at Seattle Pier 91 with luxury chauffeur transfer arriving',
    }}
    size="page"
    id="cruise-hero"
  />
  <TrustStrip />

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xl text-gray-700 leading-relaxed">
        Your cruise vacation begins the moment you leave home. Our cruise transportation service provides seamless door-to-door service to Seattle cruise terminals at Pier 91 and Bell Street Pier.
      </p>
    </div>
  </section>

  <section class="py-20 bg-gradient-to-r from-emerald-900 to-emerald-800 text-white">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-4xl font-bold mb-6">Ready to Book Cruise Transportation?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/book-now" class="bg-[#d4af37] hover:bg-[#b8941f] text-black px-8 py-4 rounded-lg font-semibold transition-all">BOOK NOW</a>
        <a href="tel:+12065959675" class="bg-transparent border-2 border-white hover:bg-white hover:text-emerald-900 text-white px-8 py-4 rounded-lg font-semibold transition-all">Call: (206) 595-9675</a>
      </div>
    </div>
  </section>
</MainLayout>
