{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "astro build",
    "build:fast": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "clean": "rm -rf dist .astro node_modules/.vite",
    "analyze": "ANALYZE=true npm run build",
    "lighthouse": "lighthouse https://emeraldcitylimos.com/ --view --output=html --output-path=./lighthouse-report.html",
    "lighthouse:mobile": "lighthouse https://emeraldcitylimos.com/ --preset=mobile --view --output=html --output-path=./lighthouse-mobile.html",
    "seo:check": "echo '🔍 SEO Checklist:\\n✅ Meta tags\\n✅ Schema markup\\n✅ Sitemap\\n✅ Robots.txt\\n❌ Social images (manual)\\n❌ Favicon (manual)\\n❌ Google Business (manual)'",
    "seo:audit": "node scripts/seo-audit.js",
    "heading:audit": "node scripts/heading-audit.js",
    "perf:mobile": "echo '📱 Mobile Performance Checklist:\\n✅ Images < 200KB total\\n✅ Critical CSS inlined\\n✅ LCP < 2.5s\\n✅ CLS < 0.1\\n✅ FID < 100ms'",
    "a11y:check": "echo '♿ Accessibility Checklist:\\n✅ ARIA labels\\n✅ Focus indicators\\n✅ Skip navigation\\n✅ Semantic HTML\\n✅ Touch targets 48px\\n✅ Color contrast'",
    "test:all": "npm run seo:audit && npm run heading:audit",
    "test:og": "curl -I https://emeraldcitylimos.com/og-image.jpg",
    "test:sitemap": "curl -I https://emeraldcitylimos.com/sitemap-index.xml",
    "test:robots": "curl -I https://emeraldcitylimos.com/robots.txt"
  },
